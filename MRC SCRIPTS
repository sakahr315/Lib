--- Show a toast notification.
--- @param opts { Title:string, Content:string, Type:string?, Duration:number? }
function Library:Notify(opts)
    opts = opts or {}
    local theme    = self.Theme
    local notifType = opts.Type or "info"
    local accentKey = NOTIF_COLORS[notifType] or "Primary"
    local accentCol = theme[accentKey] or theme.Primary
    local icon      = NOTIF_ICONS[notifType] or "●"
    local duration  = opts.Duration or 5

    local card = new("Frame", {
        Size                  = UDim2.new(1, 0, 0, 0),
        AutomaticSize         = Enum.AutomaticSize.Y,
        BackgroundColor3      = theme.SurfaceElevated,
        BackgroundTransparency = 1,
        Parent                = NotifHolder,
    })
    corner(card, 10)
    stroke(card, theme.Border, 1, 0.88)
    pad(card, nil, 14, 14, 10, 12)

    -- left accent stripe
    new("Frame", {
        Size             = UDim2.new(0, 3, 1, -20),
        Position         = UDim2.new(0, 0, 0, 10),
        BackgroundColor3 = accentCol,
        BorderSizePixel  = 0,
        Parent           = card,
    })

    -- icon + title row
    local titleRow = new("Frame", {
        BackgroundTransparency = 1,
        Size                   = UDim2.new(1, 0, 0, 18),
        Parent                 = card,
    })
    new("TextLabel", {
        BackgroundTransparency = 1,
        Size                   = UDim2.new(0, 18, 1, 0),
        Font                   = FONT_BOLD,
        TextSize               = 14,
        TextColor3             = accentCol,
        Text                   = icon,
        TextXAlignment         = Enum.TextXAlignment.Left,
        Parent                 = titleRow,
    })
    local titleLbl = new("TextLabel", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(0, 22, 0, 0),
        Size                   = UDim2.new(1, -22, 1, 0),
        Font                   = FONT_BOLD,
        TextSize               = 14,
        TextColor3             = theme.Foreground,
        TextXAlignment         = Enum.TextXAlignment.Left,
        Text                   = opts.Title or "Notification",
        Parent                 = titleRow,
    })
    local bodyLbl = new("TextLabel", {
        BackgroundTransparency = 1,
        Size                   = UDim2.new(1, 0, 0, 0),
        AutomaticSize          = Enum.AutomaticSize.Y,
        Font                   = FONT_REG,
        TextSize               = 12,
        TextColor3             = theme.MutedForeground,
        TextWrapped            = true,
        TextXAlignment         = Enum.TextXAlignment.Left,
        Text                   = opts.Content or "",
        Parent                 = card,
    })
    listL(card, 4)

    -- progress bar
    local barBg = new("Frame", {
        Size             = UDim2.new(1, 0, 0, 2),
        BackgroundColor3 = theme.Surface,
        BorderSizePixel  = 0,
        Parent           = card,
    })
    corner(barBg, 2)
    local bar = new("Frame", {
        Size             = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = accentCol,
        BorderSizePixel  = 0,
        Parent           = barBg,
    })
    corner(bar, 2)
    tw(bar, TweenInfo.new(duration, Enum.EasingStyle.Linear), { Size = UDim2.new(0, 0, 1, 0) })

    -- animate in
    card.BackgroundTransparency = 1
    titleLbl.TextTransparency   = 1
    bodyLbl.TextTransparency    = 1
    tw(card,     TI, { BackgroundTransparency = 0 })
    tw(titleLbl, TI, { TextTransparency = 0 })
    tw(bodyLbl,  TI, { TextTransparency = 0 })

    -- dismiss on click
    local btn = new("TextButton", {
        Size                  = UDim2.new(1,0,1,0),
        BackgroundTransparency = 1,
        Text                  = "",
        ZIndex                = card.ZIndex + 1,
        Parent                = card,
    })

    local function dismiss()
        tw(card,     TI, { BackgroundTransparency = 1 })
        tw(titleLbl, TI, { TextTransparency = 1 })
        tw(bodyLbl,  TI, { TextTransparency = 1 })
        task.wait(0.25)
        pcall(function() card:Destroy() end)
    end

    btn.MouseButton1Click:Connect(dismiss)
    task.delay(duration, dismiss)
end

