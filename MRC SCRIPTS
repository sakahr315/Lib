-- 3. INPUT ROUTER  (single global handler, components register here)
-- =========================================================================
local InputRouter = {
    _began   = {},
    _ended   = {},
    _changed = {},
}

local _routerConns = {}
_routerConns[1] = UIS.InputBegan:Connect(function(input, gp)
    for _, fn in pairs(InputRouter._began) do pcall(fn, input, gp) end
end)
_routerConns[2] = UIS.InputEnded:Connect(function(input, gp)
    for _, fn in pairs(InputRouter._ended) do pcall(fn, input, gp) end
end)
_routerConns[3] = UIS.InputChanged:Connect(function(input, gp)
    for _, fn in pairs(InputRouter._changed) do pcall(fn, input, gp) end
end)

local function routerListen(bucket, fn)
    local id = {}
    InputRouter[bucket][id] = fn
    return function() InputRouter[bucket][id] = nil end
end

