        -- ================================================================
        -- Window methods
        -- ================================================================
        function Win:Destroy()
            self._destroyed = true
            saveConfig(self)
            for _, unlisten in ipairs(self._connections) do unlisten() end
            if self._themeUnreg then self._themeUnreg() end
            for _, c in ipairs(_routerConns) do pcall(function() c:Disconnect() end) end
            Root:Destroy()
            OpenIcon:Destroy()
        end

        function Win:SetTitle(t)
            titleLbl.Text = t .. " · " .. hubSuffix
