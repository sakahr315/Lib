            -- ============ DROPDOWN ============
            function Tab:CreateDropdown(o)
                o = o or {}
                local multi   = o.MultipleOptions or false
                local options = o.Options or {}
                local current = o.CurrentOption or (multi and {} or options[1])

                local f = elementCard(40)
                f.ClipsDescendants = true
                new("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 12, 0, 0),
                    Size = UDim2.new(1, -150, 0, 40),
                    Font = FONT_MED, TextSize = 13,
                    TextColor3 = theme.Foreground,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Text = o.Name or "Dropdown", Parent = f,
                })
                local btn = new("TextButton", {
                    AnchorPoint = Vector2.new(1, 0),
                    Position = UDim2.new(1, -10, 0, 8),
                    Size = UDim2.new(0, 130, 0, 24),
                    BackgroundColor3 = theme.SurfaceElevated,
                    Font = FONT_MED, TextSize = 12,
                    TextColor3 = theme.Foreground,
                    AutoButtonColor = false,
                    Parent = f,
                })
                corner(btn, 6)

                local list = new("Frame", {
                    Position = UDim2.new(0, 12, 0, 44),
                    Size = UDim2.new(1, -24, 0, 0),
                    BackgroundColor3 = theme.SurfaceElevated,
                    BorderSizePixel = 0,
                    ClipsDescendants = true,
                    Parent = f,
                })
                corner(list, 6)
                local listLay = listLayout(list, 0)
                padding(list, 4)

                local api = {}
                api.CurrentOption = current

                local function labelText()
                    if multi then
                        if type(current) == "table" and #current > 0 then
                            return table.concat(current, ", ")
                        end
                        return "None"
                    end
                    return tostring(current or "Select…")
                end

                local function close()
                    tween(f, QUICK_TWEEN, { Size = UDim2.new(1, 0, 0, 40) })
                    tween(list, QUICK_TWEEN, { Size = UDim2.new(1, -24, 0, 0) })
                end
                local opened = false
                btn.Text = labelText() .. "  ▾"

                local function rebuild()
                    for _, c in ipairs(list:GetChildren()) do
                        if c:IsA("TextButton") then c:Destroy() end
                    end
                    for _, opt in ipairs(options) do
                        local item = new("TextButton", {
                            Size = UDim2.new(1, 0, 0, 26),
                            BackgroundColor3 = theme.SurfaceElevated,
                            BackgroundTransparency = 1,
                            Font = FONT_REG, TextSize = 12,
                            TextColor3 = theme.Foreground,
                            TextXAlignment = Enum.TextXAlignment.Left,
                            Text = "  " .. tostring(opt),
                            AutoButtonColor = false,
                            Parent = list,
                        })
                        corner(item, 4)
                        item.MouseEnter:Connect(function() tween(item, QUICK_TWEEN, { BackgroundTransparency = 0, BackgroundColor3 = theme.Card }) end)
                        item.MouseLeave:Connect(function() tween(item, QUICK_TWEEN, { BackgroundTransparency = 1 }) end)
                        item.MouseButton1Click:Connect(function()
                            if multi then
                                current = type(current) == "table" and current or {}
                                local found
                                for i, v in ipairs(current) do
                                    if v == opt then found = i; break end
                                end
                                if found then table.remove(current, found)
                                else table.insert(current, opt) end
                            else
                                current = opt
                                opened = false; close()
                            end
                            api.CurrentOption = current
                            btn.Text = labelText() .. "  ▾"
                            if o.Callback then task.spawn(o.Callback, current) end
                            saveConfig(Window)
                        end)
                    end
                end
                rebuild()

                btn.MouseButton1Click:Connect(function()
                    opened = not opened
                    if opened then
                        local listH = math.min(#options * 26 + 8, 160)
                        tween(f, QUICK_TWEEN, { Size = UDim2.new(1, 0, 0, 44 + listH + 6) })
                        tween(list, QUICK_TWEEN, { Size = UDim2.new(1, -24, 0, listH) })
                    else close() end
                end)

                function api:Set(v) current = v; api.CurrentOption = v; btn.Text = labelText() .. "  ▾" end
                function api:Refresh(newOptions, keep)
                    options = newOptions or {}
                    if not keep then current = multi and {} or options[1] end
                    api.CurrentOption = current
                    btn.Text = labelText() .. "  ▾"
                    rebuild()
                end

                if o.Flag then Library.Flags[o.Flag] = api end
                if Window._pendingConfig and o.Flag and Window._pendingConfig[o.Flag] ~= nil then
                    api:Set(Window._pendingConfig[o.Flag])
                end
                return api
            end

            -- ============ COLOR PICKER ============
            function Tab:CreateColorPicker(o)
                o = o or {}
                local color = o.Color or Color3.fromRGB(255, 255, 255)
                local f = elementCard(40)
                f.ClipsDescendants = true
                new("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 12, 0, 0),
                    Size = UDim2.new(1, -60, 0, 40),
                    Font = FONT_MED, TextSize = 13,
                    TextColor3 = theme.Foreground,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Text = o.Name or "Color", Parent = f,
                })
                local swatch = new("TextButton", {
                    AnchorPoint = Vector2.new(1, 0.5),
                    Position = UDim2.new(1, -10, 0, 20),
                    Size = UDim2.new(0, 36, 0, 22),
                    BackgroundColor3 = color,
                    Text = "", AutoButtonColor = false,
                    Parent = f,
                })
                corner(swatch, 6); stroke(swatch, theme.Border, 1, 0.85)

                local panel = new("Frame", {
                    Position = UDim2.new(0, 12, 0, 48),
                    Size = UDim2.new(1, -24, 0, 0),
                    BackgroundColor3 = theme.SurfaceElevated,
                    ClipsDescendants = true,
                    Parent = f,
                })
                corner(panel, 6); padding(panel, 8)
                local panelLay = listLayout(panel, 6)

                local api = {}
                api.Color = color

                local function makeChannel(name, init, cb)
                    local row = new("Frame", { Size = UDim2.new(1,0,0,22), BackgroundTransparency = 1, Parent = panel })
                    new("TextLabel", {
                        BackgroundTransparency = 1, Size = UDim2.new(0, 16, 1, 0),
                        Font = FONT_MED, TextSize = 12,
                        TextColor3 = theme.MutedForeground,
                        Text = name, Parent = row,
                    })
                    local track = new("Frame", {
                        Position = UDim2.new(0, 22, 0.5, -3),
                        Size = UDim2.new(1, -64, 0, 6),
                        BackgroundColor3 = theme.Surface,
                        BorderSizePixel = 0, Parent = row,
                    })
                    corner(track, 3)
                    local fill = new("Frame", {
                        Size = UDim2.new(init/255, 0, 1, 0),
                        BackgroundColor3 = theme.Primary,
                        BorderSizePixel = 0, Parent = track,
                    })
                    corner(fill, 3)
                    local lbl = new("TextLabel", {
                        AnchorPoint = Vector2.new(1, 0.5),
                        Position = UDim2.new(1, 0, 0.5, 0),
                        Size = UDim2.new(0, 36, 1, 0),
                        BackgroundTransparency = 1,
                        Font = FONT_MED, TextSize = 12,
                        TextColor3 = theme.Foreground,
                        Text = tostring(math.floor(init)),
                        Parent = row,
                    })
                    local dragging
                    local function setA(a)
                        a = math.clamp(a, 0, 1)
                        fill.Size = UDim2.new(a, 0, 1, 0)
                        local v = math.floor(a * 255 + 0.5)
                        lbl.Text = tostring(v)
                        cb(v)
                    end
                    track.InputBegan:Connect(function(i)
                        if i.UserInputType == Enum.UserInputType.MouseButton1
                        or i.UserInputType == Enum.UserInputType.Touch then
                            dragging = true
                            setA((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X)
                        end
                    end)
                    UserInputService.InputEnded:Connect(function(i)
                        if i.UserInputType == Enum.UserInputType.MouseButton1
                        or i.UserInputType == Enum.UserInputType.Touch then dragging = false end
                    end)
                    UserInputService.InputChanged:Connect(function(i)
                        if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement
                        or i.UserInputType == Enum.UserInputType.Touch) then
                            setA((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X)
                        end
                    end)
                end

                local r, g, b = math.floor(color.R*255), math.floor(color.G*255), math.floor(color.B*255)
                local function commit()
                    color = Color3.fromRGB(r, g, b)
                    swatch.BackgroundColor3 = color
                    api.Color = color
                    if o.Callback then task.spawn(o.Callback, color) end
                    saveConfig(Window)
                end
                makeChannel("R", r, function(v) r = v; commit() end)
                makeChannel("G", g, function(v) g = v; commit() end)
                makeChannel("B", b, function(v) b = v; commit() end)

                local opened = false
                swatch.MouseButton1Click:Connect(function()
                    opened = not opened
                    if opened then
                        tween(f, QUICK_TWEEN, { Size = UDim2.new(1, 0, 0, 48 + 22*3 + 6*2 + 16) })
                        tween(panel, QUICK_TWEEN, { Size = UDim2.new(1, -24, 0, 22*3 + 6*2 + 16) })
                    else
                        tween(f, QUICK_TWEEN, { Size = UDim2.new(1, 0, 0, 40) })
                        tween(panel, QUICK_TWEEN, { Size = UDim2.new(1, -24, 0, 0) })
                    end
                end)

                function api:Set(c)
                    color = c; r,g,b = math.floor(c.R*255), math.floor(c.G*255), math.floor(c.B*255)
                    swatch.BackgroundColor3 = color
                    api.Color = color
                end
                if o.Flag then Library.Flags[o.Flag] = api end
                return api
            end

            return Tab
        end -- CreateTab

        table.insert(self.Windows, Window)
        loadConfig(Window)

        -- Discord prompt
        if opts.Discord and opts.Discord.Enabled and opts.Discord.Invite then
            task.delay(0.5, function()
                _setclipboard("https://discord.gg/" .. opts.Discord.Invite)
                Library:Notify({
                    Title = "Discord",
                    Content = "Invite copied to clipboard: " .. opts.Discord.Invite,
                    Duration = 6,
                })
            end)
        end

        return Window
    end

    -- Key gate
    if opts.KeySystem then
        local result
        runKeySystem(opts.KeySettings or {}, function() result = actuallyBuild() end)
        -- return a stub that proxies later; most consumers expect immediate return,
        -- but loaders typically check KeySystem before binding tabs. Block:
        while not result do task.wait(0.1) end
        return result
    end

    return actuallyBuild()
end

return Library
