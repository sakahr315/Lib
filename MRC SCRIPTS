        -- ================================================================
        -- TAB
        -- ================================================================
        function Win:Tab(name)
            local Tab = { _win = self }

            local TabBtn = new("TextButton", {
                Size                   = UDim2.new(1, 0, 0, 34),
                BackgroundColor3       = theme.SurfaceElevated,
                BackgroundTransparency = 1,
                Text                   = name or "Tab",
                TextXAlignment         = Enum.TextXAlignment.Left,
                Font                   = FONT_MED, TextSize = 12,
                TextColor3             = theme.MutedForeground,
                AutoButtonColor        = false,
                Parent                 = SideScroll,
            })
            corner(TabBtn, 6)
            pad(TabBtn, nil, 14, 8, 0, 0)

            -- Left accent bar — visible only when active
            local TabBar = new("Frame", {
                Position               = UDim2.new(0, 0, 0.5, -10),
                Size                   = UDim2.new(0, 3, 0, 20),
                BackgroundColor3       = theme.Primary,
                BackgroundTransparency = 1,
                BorderSizePixel        = 0,
                Parent                 = TabBtn,
            })

            local _isActive = false
            TabBtn.MouseEnter:Connect(function()
                if not _isActive then
                    tw(TabBtn, TI_Q, { BackgroundTransparency = 0.7 })
                end
            end)
            TabBtn.MouseLeave:Connect(function()
                if not _isActive then
                    tw(TabBtn, TI_Q, { BackgroundTransparency = 1 })
                end
            end)

            local Page = new("ScrollingFrame", {
                Size                   = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                BorderSizePixel        = 0,
                Visible                = false,
                ScrollBarThickness     = 3,
                ScrollBarImageColor3   = theme.Primary,
                CanvasSize             = UDim2.new(0, 0, 0, 0),
                AutomaticCanvasSize    = Enum.AutomaticSize.Y,
                Parent                 = Pages,
            })
            listL(Page, 10)
            pad(Page, nil, 20, 20, 16, 16)

            -- Scroll fade at bottom
            new("UIGradient", {
                Transparency = NumberSequence.new{
                    NumberSequenceKeypoint.new(0,    0),
                    NumberSequenceKeypoint.new(0.93, 0),
                    NumberSequenceKeypoint.new(1,    1),
                },
                Rotation = 90,
                Parent   = Page,
            })

            Tab._page     = Page
            Tab._btn      = TabBtn
            Tab._bar      = TabBar
            Tab._isActive = false

            local function activate()
                for _, t in ipairs(self.Tabs) do
                    t._page.Visible = false
                    t._isActive     = false
                    tw(t._btn, TI_Q, {
                        BackgroundTransparency = 1,
                        TextColor3             = theme.MutedForeground,
                    })
                    if t._bar then tw(t._bar, TI_Q, { BackgroundTransparency = 1 }) end
                end
                Page.Visible  = true
                _isActive     = true
                Tab._isActive = true
                tw(TabBtn, TI_Q, {
                    BackgroundColor3       = theme.SurfaceElevated,
                    BackgroundTransparency = 0,
                    TextColor3             = theme.Foreground,
                })
                tw(TabBar, TI_Q, { BackgroundTransparency = 0 })
            end

            TabBtn.MouseButton1Click:Connect(activate)
            table.insert(self.Tabs, Tab)
            if #self.Tabs == 1 then activate() end

            -- ============================================================
            -- Shared element helpers
            -- ============================================================

            -- Base card: adds sheen and border
            local function card(height)
                local f = new("Frame", {
                    Size             = UDim2.new(1, 0, 0, height or 52),
                    BackgroundColor3 = theme.Card,
                    BorderSizePixel  = 0,
                    Parent           = Page,
                })
                corner(f, 8)
                stroke(f, theme.Border, 1, 0.92)
                sheen(f)
                return f
            end

            -- Context menu attachment
            local function attachCtx(frame, items)
                if not items or #items == 0 then return end
                frame.InputBegan:Connect(function(input)
                    if input.UserInputType ~= Enum.UserInputType.MouseButton2 then return end
                    for _, c in ipairs(CtxList:GetChildren()) do
                        if c:IsA("TextButton") then c:Destroy() end
                    end
                    CtxMenu.BackgroundColor3 = theme.SurfaceElevated
                    local itemH = 28
                    for _, item in ipairs(items) do
                        local b = new("TextButton", {
                            Size                   = UDim2.new(1, 0, 0, itemH),
                            BackgroundTransparency = 1,
                            BackgroundColor3       = theme.Card,
                            Font                   = FONT_MED, TextSize = 12,
                            TextColor3             = theme.Foreground,
                            TextXAlignment         = Enum.TextXAlignment.Left,
                            Text                   = "  " .. (item.Icon and (item.Icon .. "  ") or "") .. (item.Label or ""),
                            AutoButtonColor        = false,
                            Parent                 = CtxList,
                        })
                        corner(b, 4)
                        b.MouseEnter:Connect(function() tw(b, TI_Q, { BackgroundTransparency = 0 }) end)
                        b.MouseLeave:Connect(function() tw(b, TI_Q, { BackgroundTransparency = 1 }) end)
                        b.MouseButton1Click:Connect(function()
                            hideCtx()
                            if item.Callback then safeCallback(item.Callback, notifyFn)() end
                        end)
                    end
                    local totalH = #items * itemH + 8
                    local mp = UIS:GetMouseLocation()
                    CtxMenu.Position = UDim2.new(0, mp.X + 4, 0, mp.Y + 4)
                    CtxMenu.Visible  = true
                    ctxOpen          = true
                    tw(CtxMenu, TI_Q, { Size = UDim2.new(0, 160, 0, totalH) })
                end)
            end

            -- ============================================================
            -- SECTION
            -- ============================================================
            function Tab:Section(name)
                local container = new("Frame", {
                    BackgroundTransparency = 1,
                    Size                   = UDim2.new(1, 0, 0, 22),
                    Parent                 = Page,
                })
                -- Left accent pip (muted, not full cyan)
                new("Frame", {
                    Position               = UDim2.new(0, 0, 0.5, -5),
                    Size                   = UDim2.new(0, 3, 0, 10),
                    BackgroundColor3       = theme.Primary,
                    BackgroundTransparency = 0.45,
                    BorderSizePixel        = 0,
                    Parent                 = container,
                })
                local lbl = new("TextLabel", {
                    BackgroundTransparency = 1,
                    Position               = UDim2.new(0, 10, 0, 0),
                    Size                   = UDim2.new(1, -10, 1, 0),
                    Font                   = FONT_MED, TextSize = 10,
                    TextColor3             = theme.MutedForeground,
                    TextXAlignment         = Enum.TextXAlignment.Left,
                    Text                   = string.upper(name or "Section"),
                    Parent                 = container,
                })
                return {
                    Set    = function(_, t) lbl.Text = string.upper(t) end,
                    Remove = function()     container:Destroy() end,
                }
            end

            -- ============================================================
            -- BUTTON
            -- ============================================================
            function Tab:Button(opts)
                opts = opts or {}
                local f = card(52)

                -- Left hover indicator bar
