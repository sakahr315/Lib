local function getParent()
    local ok, hui = pcall(function() return _gethui and _gethui() end)
    if ok and hui then return hui end
    if RunService:IsStudio() then return LocalPlayer:WaitForChild("PlayerGui") end
    local ok2, cg = pcall(function() return CoreGui end)
    return (ok2 and cg) or LocalPlayer:WaitForChild("PlayerGui")
end

