    })
    new("TextLabel", {
        BackgroundTransparency = 1,
        Position       = UDim2.new(0, 16, 0, 62),
        Size           = UDim2.new(1, -32, 0, 30),
        Font           = FONT_REG, TextSize = 12,
        TextColor3     = theme.MutedForeground,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped    = true,
        Text           = opts.Note or "",
        Parent         = box,
    })

    local input = new("TextBox", {
        Position          = UDim2.new(0, 16, 0, 100),
        Size              = UDim2.new(1, -32, 0, 36),
        BackgroundColor3  = theme.SurfaceElevated,
        Font              = FONT_REG, TextSize = 14,
        TextColor3        = theme.Foreground,
        PlaceholderText   = "Enter key…",
        PlaceholderColor3 = theme.MutedForeground,
        ClearTextOnFocus  = false,
        Text              = "",
        Parent            = box,
    })
    corner(input, 8)
    local inputStroke = stroke(input, theme.Border, 1, 0.9)
    pad(input, nil, 10, 10, 0, 0)

    input.Focused:Connect(function()
        tw(inputStroke, TI_Q, { Color = theme.Primary, Transparency = 0.5 })
    end)
    input.FocusLost:Connect(function()
        tw(inputStroke, TI_Q, { Color = theme.Border, Transparency = 0.9 })
    end)

    local function mkBtn(text, x, w, bg, fg)
        local b = new("TextButton", {
            Position         = UDim2.new(0, x, 1, -52),
            Size             = UDim2.new(0, w, 0, 36),
            BackgroundColor3 = bg,
            TextColor3       = fg,
            Font             = FONT_MED, TextSize = 13,
            Text             = text,
            AutoButtonColor  = false,
            Parent           = box,
        })
        corner(b, 8)
        b.MouseEnter:Connect(function() tw(b, TI_Q, { BackgroundColor3 = theme.PrimaryGlow }) end)
        b.MouseLeave:Connect(function() tw(b, TI_Q, { BackgroundColor3 = bg }) end)
        return b
    end

    local checkBtn = mkBtn("Confirm", 16, 110, theme.Primary, theme.PrimaryForeground)
    local getBtn   = opts.GrabKeyFromSite and mkBtn("Get Key", 134, 110, theme.SurfaceElevated, theme.Foreground)
    local quitBtn  = mkBtn("Cancel", 360 - 16 - 90, 90, theme.SurfaceElevated, theme.Foreground)

    if getBtn then
        getBtn.MouseButton1Click:Connect(function()
            _setclipboard(opts.GrabKeyFromSite)
            notifyFn({ Title = "Key Link Copied", Content = opts.GrabKeyFromSite, Type = "info", Duration = 5 })
        end)
    end
    quitBtn.MouseButton1Click:Connect(function() overlay:Destroy() end)
    checkBtn.MouseButton1Click:Connect(function()
        local v = input.Text
        for _, k in ipairs(keys) do
            if v == k then
                if opts.SaveKey then pcall(_writefile, fileName .. ".txt", v) end
                overlay:Destroy(); onPass(); return
            end
        end
        notifyFn({ Title = "Invalid Key", Content = "That key did not match.", Type = "error", Duration = 4 })
        tw(input, TI_Q, { BackgroundColor3 = theme.Destructive })
        task.delay(0.4, function() tw(input, TI_Q, { BackgroundColor3 = theme.SurfaceElevated }) end)
    end)
end

-- =========================================================================
-- 11. CONFIG  (versioned, debounced, per-element opt-out)
-- =========================================================================
local CONFIG_VERSION = 1

local function cfgPath(folder, file)
    return (folder and (folder .. "/") or "") .. (file or "Config") .. ".json"
end

local function saveConfig(window)
    local cfg = window._config
    if not (cfg and cfg.Enabled) then return end
    local data = { __version = CONFIG_VERSION }
    for flag, ref in pairs(Library.Flags) do
        if ref._saveEnabled ~= false then
            local ok, val = pcall(function() return ref.Value end)
            if ok then data[flag] = val end
        end
    end
    pcall(function()
        if cfg.FolderName and not _isfolder(cfg.FolderName) then
            _makefolder(cfg.FolderName)
        end
        _writefile(cfgPath(cfg.FolderName, cfg.FileName), HttpService:JSONEncode(data))
    end)
end

local function loadConfig(window)
    local cfg = window._config
    if not (cfg and cfg.Enabled) then return end
    local path = cfgPath(cfg.FolderName, cfg.FileName)
    if not _isfile(path) then return end
    local ok, txt = pcall(_readfile, path)
    if not ok or not txt then return end
    local ok2, data = pcall(function() return HttpService:JSONDecode(txt) end)
    if not ok2 or type(data) ~= "table" then return end
    if (data.__version or 0) < CONFIG_VERSION then
        -- future migrations go here
    end
    window._pendingConfig = data
end

