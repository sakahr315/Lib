            end

            -- ============================================================
            -- DROPDOWN — CHANGE: valBtn blends into card, no visible border
            -- ============================================================
            function Tab:Dropdown(opts2)
                opts2 = opts2 or {}
                local multi   = opts2.Multi or false
                local options = opts2.Options or {}
                local current = opts2.Default or (multi and {} or options[1])
                local f       = card(52)
                f.ClipsDescendants = true

                new("TextLabel", {
                    BackgroundTransparency = 1,
                    AnchorPoint            = Vector2.new(0, 0.5),
                    Position               = UDim2.new(0, 16, 0.5, 0),
                    Size                   = UDim2.new(1, -180, 0, 16),
                    Font                   = FONT_MED, TextSize = ts(13),
                    TextColor3             = theme.Foreground,
                    TextXAlignment         = Enum.TextXAlignment.Left,
                    Text                   = opts2.Label or "Dropdown",
                    Parent                 = f,
                })

                -- CHANGE: valBtn blends into card — same bg, no visible border
                local valBtn = new("TextButton", {
                    AnchorPoint      = Vector2.new(1, 0.5),
                    Position         = UDim2.new(1, -14, 0.5, 0),
                    Size             = UDim2.new(0, 155, 0, 28),
                    -- CHANGE: match card exactly so button is invisible
                    BackgroundColor3 = theme.Card,
                    Font             = FONT_MED, TextSize = ts(12),
                    TextColor3       = theme.MutedForeground,
                    AutoButtonColor  = false,
                    BorderSizePixel  = 0,
                    Parent           = f,
                })
                corner(valBtn, R_SM)
                -- CHANGE: nearly invisible border (0.98)
                stroke(valBtn, theme.Border, 1, 0.98)
                pad(valBtn, nil, 10, 24, 0, 0)
                valBtn.TextXAlignment = Enum.TextXAlignment.Left

                local chevron = new("TextLabel", {
                    AnchorPoint            = Vector2.new(1, 0.5),
                    Position               = UDim2.new(1, -8, 0.5, 0),
                    Size                   = UDim2.new(0, 12, 0, 12),
                    BackgroundTransparency = 1,
                    Font                   = FONT_MED, TextSize = ts(12),
                    TextColor3             = theme.MutedForeground,
                    Text                   = "▾",
                    Rotation               = 0,
                    Parent                 = valBtn,
                })

                local searchBox = new("TextBox", {
                    Position          = UDim2.new(0, 16, 0, 58),
                    Size              = UDim2.new(1, -32, 0, 26),
                    BackgroundColor3  = theme.SurfaceElevated,
                    Font              = FONT_REG, TextSize = ts(12),
                    TextColor3        = theme.Foreground,
                    PlaceholderText   = "Search…",
                    PlaceholderColor3 = theme.MutedForeground,
                    ClearTextOnFocus  = false, Text = "",
                    BackgroundTransparency = 1,
                    Parent            = f,
                })
                corner(searchBox, R_SM)
                pad(searchBox, nil, 8, 8, 0, 0)
                local searchStroke = stroke(searchBox, theme.Border, 1, 0.92)
                searchBox.Focused:Connect(function()
                    tw(searchStroke, TI_Q, { Color = theme.Primary, Transparency = 0.5 })
                end)
                searchBox.FocusLost:Connect(function()
                    tw(searchStroke, TI_Q, { Color = theme.Border, Transparency = 0.92 })
                end)

                local list = new("Frame", {
                    Position         = UDim2.new(0, 16, 0, 88),
                    Size             = UDim2.new(1, -32, 0, 0),
                    BackgroundColor3 = theme.SurfaceElevated,
                    BorderSizePixel  = 0,
                    ClipsDescendants = true,
                    Parent           = f,
                })
                corner(list, R_SM)
                listL(list, 0)
                pad(list, 4)

                local changed = Signal.new()
                local api     = {}
                api._saveEnabled = opts2.Save ~= false
                api.Value        = current

                local function labelText()
                    if multi then
                        return (type(current) == "table" and #current > 0)
                            and table.concat(current, ", ") or "None"
                    end
                    return tostring(current or "Select…")
                end

                local opened = false

                local function close()
                    opened = false
                    if _openDropdown == close then _openDropdown = nil end
                    tw(chevron,   TI_Q, { Rotation = 0 })
                    tw(f,         TI_Q, { Size = UDim2.new(1, 0, 0, 52) })
                    tw(list,      TI_Q, { Size = UDim2.new(1, -32, 0, 0) })
                    tw(searchBox, TI_Q, { BackgroundTransparency = 1 })
                    searchBox.Text = ""
                end

                local function rebuild(filter)
                    filter = filter and string.lower(filter) or ""
                    for _, c in ipairs(list:GetChildren()) do
                        if c:IsA("TextButton") then c:Destroy() end
                    end
                    local visible = 0
                    for _, opt in ipairs(options) do
                        local optStr = tostring(opt)
                        if filter == "" or string.find(string.lower(optStr), filter, 1, true) then
                            visible = visible + 1
                            local item = new("TextButton", {
                                Size                   = UDim2.new(1, 0, 0, 28),
                                BackgroundTransparency = 1,
                                BackgroundColor3       = theme.Card,
                                Font                   = FONT_REG, TextSize = ts(12),
                                TextColor3             = theme.Foreground,
                                TextXAlignment         = Enum.TextXAlignment.Left,
                                Text                   = "  " .. optStr,
                                AutoButtonColor        = false,
                                Parent                 = list,
                            })
                            corner(item, R_SM - 2)
                            item.MouseEnter:Connect(function() tw(item, TI_Q, { BackgroundTransparency = 0 }) end)
                            item.MouseLeave:Connect(function() tw(item, TI_Q, { BackgroundTransparency = 1 }) end)
                            item.MouseButton1Click:Connect(function()
                                if multi then
                                    current = type(current) == "table" and current or {}
                                    local found
                                    for i, v in ipairs(current) do
                                        if v == opt then found = i; break end
                                    end
                                    if found then table.remove(current, found)
                                    else table.insert(current, opt) end
                                else current = opt; close() end
                                api.Value = current; valBtn.Text = labelText()
                                changed:Fire(current); Win._debouncedSave()
                            end)
                        end
                    end
                    return visible
                end

                rebuild()
                valBtn.Text = labelText()

                valBtn.MouseButton1Click:Connect(function()
                    opened = not opened
                    if opened then
                        if _openDropdown and _openDropdown ~= close then
                            _openDropdown()
                        end
                        _openDropdown = close
                        tw(chevron, TI_Q, { Rotation = 180 })
                        local count = rebuild(searchBox.Text)
                        local listH = math.min(count * 28 + 8, 168)
                        tw(f,         TI_Q, { Size = UDim2.new(1, 0, 0, 96 + listH) })
                        tw(list,      TI_Q, { Size = UDim2.new(1, -32, 0, listH) })
                        tw(searchBox, TI_Q, { BackgroundTransparency = 0 })
                    else close() end
                end)

                searchBox:GetPropertyChangedSignal("Text"):Connect(function()
                    if not opened then return end
                    local count = rebuild(searchBox.Text)
                    local listH = math.min(count * 28 + 8, 168)
                    list.Size   = UDim2.new(1, -32, 0, listH)
                    f.Size      = UDim2.new(1, 0, 0, 96 + listH)
                end)

                function api:Set(v)
                    current = v; api.Value = v; valBtn.Text = labelText()
                end
                function api:Refresh(newOpts, keep)
                    options = newOpts or {}
                    if not keep then current = multi and {} or options[1] end
                    api.Value = current; valBtn.Text = labelText(); rebuild()
                end
                function api:OnChanged(fn) return changed:Connect(safeCallback(fn, notifyFn)) end
                if opts2.Flag then Library.Flags[opts2.Flag] = api end
                if Win._pendingConfig and opts2.Flag and Win._pendingConfig[opts2.Flag] ~= nil then
                    api:Set(Win._pendingConfig[opts2.Flag])
                end
                return decorate(api, f, opts2)
            end

            -- ============================================================
            -- COLOR PICKER
            -- ============================================================
            function Tab:ColorPicker(opts2)
                opts2 = opts2 or {}
                local color   = opts2.Default or Color3.fromRGB(255, 255, 255)
                local h, s, v = colorToHsv(color)
                local f       = card(40)
                f.ClipsDescendants = true

                new("TextLabel", {
                    BackgroundTransparency = 1,
                    AnchorPoint            = Vector2.new(0, 0.5),
                    Position               = UDim2.new(0, 14, 0.5, 0),
                    Size                   = UDim2.new(1, -60, 0, 16),
                    Font                   = FONT_MED, TextSize = ts(13),
                    TextColor3             = theme.Foreground,
                    TextXAlignment         = Enum.TextXAlignment.Left,
                    Text                   = opts2.Label or "Color",
                    Parent                 = f,
                })

                local swatch = new("TextButton", {
                    AnchorPoint      = Vector2.new(1, 0.5),
                    Position         = UDim2.new(1, -12, 0.5, 0),
                    Size             = UDim2.new(0, 38, 0, 24),
                    BackgroundColor3 = color,
                    Text             = "",
                    AutoButtonColor  = false,
                    Parent           = f,
                })
                corner(swatch, R_SM)
                stroke(swatch, theme.Border, 1, 0.82)

                local panel = new("Frame", {
                    Position               = UDim2.new(0, 12, 0, 48),
                    Size                   = UDim2.new(1, -24, 0, 0),
                    BackgroundTransparency = 1,
                    ClipsDescendants       = true,
                    Parent                 = f,
                })

                local svSquare = new("Frame", {
                    Size             = UDim2.new(1, 0, 0, 130),
                    BackgroundColor3 = hsvToColor(h, 1, 1),
                    BorderSizePixel  = 0,
                    Parent           = panel,
                })
                corner(svSquare, R_SM)
                new("UIGradient", {
                    Color = ColorSequence.new{
                        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
                        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255)),
                    },
                    Transparency = NumberSequence.new{
                        NumberSequenceKeypoint.new(0, 0),
                        NumberSequenceKeypoint.new(1, 1),
                    },
                    Parent = svSquare,
                })
                local svDarkLayer = new("Frame", {
                    Size                   = UDim2.new(1, 0, 1, 0),
                    BackgroundColor3       = Color3.fromRGB(0, 0, 0),
                    BackgroundTransparency = 0,
                    BorderSizePixel        = 0,
                    Parent                 = svSquare,
                })
                corner(svDarkLayer, R_SM)
                new("UIGradient", {
                    Rotation     = 90,
                    Transparency = NumberSequence.new{
                        NumberSequenceKeypoint.new(0, 1),
                        NumberSequenceKeypoint.new(1, 0),
                    },
                    Parent = svDarkLayer,
                })
                local svCursor = new("Frame", {
                    AnchorPoint      = Vector2.new(0.5, 0.5),
                    Position         = UDim2.new(s, 0, 1 - v, 0),
                    Size             = UDim2.new(0, 10, 0, 10),
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    ZIndex           = svSquare.ZIndex + 2,
                    BorderSizePixel  = 0,
                    Parent           = svSquare,
                })
                corner(svCursor, R_PILL)
                stroke(svCursor, Color3.fromRGB(0, 0, 0), 1, 0.5)

                local hueBar = new("Frame", {
                    Position        = UDim2.new(0, 0, 0, 138),
                    Size            = UDim2.new(1, 0, 0, 14),
                    BorderSizePixel = 0,
                    Parent          = panel,
                })
                corner(hueBar, R_SM)
                new("UIGradient", {
                    Color = ColorSequence.new{
                        ColorSequenceKeypoint.new(0/6, Color3.fromRGB(255, 0,   0)),
                        ColorSequenceKeypoint.new(1/6, Color3.fromRGB(255, 255, 0)),
                        ColorSequenceKeypoint.new(2/6, Color3.fromRGB(0,   255, 0)),
                        ColorSequenceKeypoint.new(3/6, Color3.fromRGB(0,   255, 255)),
                        ColorSequenceKeypoint.new(4/6, Color3.fromRGB(0,   0,   255)),
                        ColorSequenceKeypoint.new(5/6, Color3.fromRGB(255, 0,   255)),
                        ColorSequenceKeypoint.new(6/6, Color3.fromRGB(255, 0,   0)),
                    },
                    Parent = hueBar,
                })
                local hueCursor = new("Frame", {
                    AnchorPoint      = Vector2.new(0.5, 0.5),
                    Position         = UDim2.new(h, 0, 0.5, 0),
                    Size             = UDim2.new(0, 6, 1, 4),
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    ZIndex           = hueBar.ZIndex + 1,
                    BorderSizePixel  = 0,
                    Parent           = hueBar,
                })
                corner(hueCursor, 3)
                stroke(hueCursor, Color3.fromRGB(0, 0, 0), 1, 0.4)

                local hexRow = new("Frame", {
                    Position               = UDim2.new(0, 0, 0, 160),
                    Size                   = UDim2.new(1, 0, 0, 26),
                    BackgroundTransparency = 1,
                    Parent                 = panel,
                })
                new("TextLabel", {
                    BackgroundTransparency = 1,
                    Size                   = UDim2.new(0, 28, 1, 0),
                    Font                   = FONT_MED, TextSize = ts(11),
                    TextColor3             = theme.MutedForeground,
                    Text                   = "HEX",
                    Parent                 = hexRow,
                })
                local hexBox = new("TextBox", {
                    Position          = UDim2.new(0, 32, 0, 0),
                    Size              = UDim2.new(1, -32, 1, 0),
                    BackgroundColor3  = theme.SurfaceElevated,
                    Font              = FONT_MED, TextSize = ts(12),
                    TextColor3        = theme.Foreground,
                    ClearTextOnFocus  = false, Text = "",
                    Parent            = hexRow,
                })
                corner(hexBox, R_SM - 2)
                pad(hexBox, nil, 6, 6, 0, 0)
                local hexStroke = stroke(hexBox, theme.Border, 1, 0.9)
                hexBox.Focused:Connect(function()
                    tw(hexStroke, TI_Q, { Color = theme.Primary, Transparency = 0.5 })
                end)
                hexBox.FocusLost:Connect(function()
                    tw(hexStroke, TI_Q, { Color = theme.Border, Transparency = 0.9 })
                end)

                local changed = Signal.new()
                local api     = {}
                api._saveEnabled = opts2.Save ~= false
                api.Value        = color

                local function toHex(c)
                    return string.format("#%02X%02X%02X",
                        math.floor(c.R * 255), math.floor(c.G * 255), math.floor(c.B * 255))
                end

                local _suppressHex = false
                local function commit()
                    color     = hsvToColor(h, s, v)
                    api.Value = color
                    swatch.BackgroundColor3   = color
                    svSquare.BackgroundColor3 = hsvToColor(h, 1, 1)
                    svCursor.Position         = UDim2.new(s, 0, 1 - v, 0)
                    hueCursor.Position        = UDim2.new(h, 0, 0.5, 0)
                    if not _suppressHex then
                        hexBox.Text = toHex(color)
                    end
                    changed:Fire(color)
                    Win._debouncedSave()
                end
                commit()

                local hexDebounce = debounce(function()
                    local txt = hexBox.Text:gsub("#", "")
                    if #txt == 6 then
                        local r_ = tonumber(txt:sub(1, 2), 16)
                        local g_ = tonumber(txt:sub(3, 4), 16)
                        local b_ = tonumber(txt:sub(5, 6), 16)
                        if r_ and g_ and b_ then
                            tw(hexStroke, TI_Q, { Color = theme.Primary, Transparency = 0.5 })
                            _suppressHex = true
                            h, s, v = colorToHsv(Color3.fromRGB(r_, g_, b_))
                            commit()
                            _suppressHex = false
                        else
                            tw(hexStroke, TI_Q, { Color = theme.Destructive, Transparency = 0.4 })
                        end
                    else
                        if #txt > 0 then
                            tw(hexStroke, TI_Q, { Color = theme.Destructive, Transparency = 0.4 })
                        end
                    end
                end, 0.25)

                hexBox:GetPropertyChangedSignal("Text"):Connect(function()
                    if not hexBox:IsFocused() then return end
                    hexDebounce()
                end)

                hexBox.FocusLost:Connect(function()
                    local txt = hexBox.Text:gsub("#", "")
                    if #txt == 6 then
                        local r_ = tonumber(txt:sub(1, 2), 16)
                        local g_ = tonumber(txt:sub(3, 4), 16)
                        local b_ = tonumber(txt:sub(5, 6), 16)
                        if r_ and g_ and b_ then
                            tw(hexStroke, TI_Q, { Color = theme.Border, Transparency = 0.9 })
                            _suppressHex = true
                            h, s, v = colorToHsv(Color3.fromRGB(r_, g_, b_))
                            commit()
                            _suppressHex = false
                        else
                            tw(hexStroke, TI_Q, { Color = theme.Destructive, Transparency = 0.4 })
                            task.delay(0.8, function()
                                hexBox.Text = toHex(color)
                                tw(hexStroke, TI_Q, { Color = theme.Border, Transparency = 0.9 })
                            end)
                        end
                    else
                        hexBox.Text = toHex(color)
                        tw(hexStroke, TI_Q, { Color = theme.Border, Transparency = 0.9 })
                    end
                end)

                local svDrag = false
                local svU1 = routerListen("_began", function(input)
                    if input.UserInputType ~= Enum.UserInputType.MouseButton1
                    and input.UserInputType ~= Enum.UserInputType.Touch then return end
                    local ap = svSquare.AbsolutePosition; local sz = svSquare.AbsoluteSize
                    local mp = input.Position
                    if mp.X >= ap.X and mp.X <= ap.X + sz.X and mp.Y >= ap.Y and mp.Y <= ap.Y + sz.Y then
                        svDrag = true
                        s = math.clamp((mp.X - ap.X) / sz.X, 0, 1)
                        v = 1 - math.clamp((mp.Y - ap.Y) / sz.Y, 0, 1)
                        commit()
                    end
                end)
                local svU2 = routerListen("_ended", function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch then svDrag = false end
                end)
                local svU3 = routerListen("_changed", function(input)
                    if not svDrag then return end
                    if input.UserInputType ~= Enum.UserInputType.MouseMovement
                    and input.UserInputType ~= Enum.UserInputType.Touch then return end
                    local ap = svSquare.AbsolutePosition; local sz = svSquare.AbsoluteSize
                    s = math.clamp((input.Position.X - ap.X) / sz.X, 0, 1)
                    v = 1 - math.clamp((input.Position.Y - ap.Y) / sz.Y, 0, 1)
                    commit()
                end)

                local hueDrag = false
                local hU1 = routerListen("_began", function(input)
                    if input.UserInputType ~= Enum.UserInputType.MouseButton1
                    and input.UserInputType ~= Enum.UserInputType.Touch then return end
                    local ap = hueBar.AbsolutePosition; local sz = hueBar.AbsoluteSize
                    local mp = input.Position
                    if mp.X >= ap.X and mp.X <= ap.X + sz.X and mp.Y >= ap.Y and mp.Y <= ap.Y + sz.Y then
                        hueDrag = true; h = math.clamp((mp.X - ap.X) / sz.X, 0, 1); commit()
                    end
                end)
                local hU2 = routerListen("_ended", function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch then hueDrag = false end
                end)
                local hU3 = routerListen("_changed", function(input)
                    if not hueDrag then return end
                    if input.UserInputType ~= Enum.UserInputType.MouseMovement
                    and input.UserInputType ~= Enum.UserInputType.Touch then return end
                    h = math.clamp(
                        (input.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
                    commit()
                end)

                for _, u in ipairs({ svU1, svU2, svU3, hU1, hU2, hU3 }) do
                    table.insert(Win._connections, u)
                end

                local opened = false
                swatch.MouseButton1Click:Connect(function()
                    opened = not opened
                    if opened then
                        tw(f,     TI_Q, { Size = UDim2.new(1, 0, 0, 48 + 196) })
                        tw(panel, TI_Q, { Size = UDim2.new(1, -24, 0, 196) })
                    else
                        tw(f,     TI_Q, { Size = UDim2.new(1, 0, 0, 40) })
                        tw(panel, TI_Q, { Size = UDim2.new(1, -24, 0, 0) })
                    end
                end)

                function api:Set(c) color = c; h, s, v = colorToHsv(c); commit() end
                function api:OnChanged(fn) return changed:Connect(safeCallback(fn, notifyFn)) end
                if opts2.Flag then Library.Flags[opts2.Flag] = api end
                return decorate(api, f, opts2)
            end

            -- ============================================================
            -- PROGRESS BAR
            -- ============================================================
            function Tab:ProgressBar(opts2)
                opts2   = opts2 or {}
                local max_v  = opts2.Max or 100
                local val    = math.clamp(opts2.Initial or 0, 0, max_v)
                local suffix = opts2.Suffix or "%"
                local f      = card(52)

                new("TextLabel", {
                    BackgroundTransparency = 1,
                    Position   = UDim2.new(0, 14, 0, 8), Size = UDim2.new(1, -28, 0, 16),
                    Font       = FONT_MED, TextSize = ts(13),
                    TextColor3 = theme.Foreground, TextXAlignment = Enum.TextXAlignment.Left,
                    Text       = opts2.Label or "Progress", Parent = f,
                })
                local pct = new("TextLabel", {
                    BackgroundTransparency = 1,
                    Position   = UDim2.new(1, -60, 0, 8), Size = UDim2.new(0, 48, 0, 16),
                    Font       = FONT_MED, TextSize = ts(12),
                    TextColor3 = theme.Primary, TextXAlignment = Enum.TextXAlignment.Right,
                    Text       = tostring(val) .. suffix, Parent = f,
                })
                local track = new("Frame", {
                    Position         = UDim2.new(0, 14, 1, -18),
                    Size             = UDim2.new(1, -28, 0, 6),
                    BackgroundColor3 = theme.SurfaceElevated,
                    BorderSizePixel  = 0, Parent = f,
                })
                corner(track, 3)
                local fill = new("Frame", {
                    Size             = UDim2.new(val / max_v, 0, 1, 0),
                    BackgroundColor3 = theme.Primary,
                    BorderSizePixel  = 0, Parent = track,
                })
                corner(fill, 3)

                local api = {}; api.Value = val
                function api:Set(newVal, animated)
                    newVal    = math.clamp(newVal, 0, max_v); api.Value = newVal
                    pct.Text  = tostring(math.floor(newVal)) .. suffix
                    local target = UDim2.new(newVal / max_v, 0, 1, 0)
                    if animated ~= false then tw(fill, TI, { Size = target }) else fill.Size = target end
                end
                function api:SetColor(c) fill.BackgroundColor3 = c end
                function api:Remove()    f:Destroy() end
                return api
            end

            -- ============================================================
            -- DATA TABLE
            -- ============================================================
            function Tab:DataTable(opts2)
                opts2 = opts2 or {}
                local cols = opts2.Columns or {}
                local rows = opts2.Rows    or {}
                local colW = #cols > 0 and (1 / #cols) or 1

                local f = new("Frame", {
                    Size             = UDim2.new(1, 0, 0, 0),
                    AutomaticSize    = Enum.AutomaticSize.Y,
                    BackgroundColor3 = theme.Card,
                    Parent           = Page,
                })
                corner(f, 6)
                stroke(f, theme.Border, 1, 0.97)
                pad(f, 8)
                listL(f, 0)

                if opts2.Label then
                    new("TextLabel", {
                        BackgroundTransparency = 1,
                        Size                   = UDim2.new(1, 0, 0, 20),
                        Font                   = FONT_BOLD, TextSize = ts(12),
                        TextColor3             = theme.Primary,
                        TextXAlignment         = Enum.TextXAlignment.Left,
                        Text                   = opts2.Label, Parent = f,
                    })
                end

                local function makeRow(data, isHeader)
                    local row = new("Frame", {
                        Size                   = UDim2.new(1, 0, 0, 26),
                        BackgroundTransparency = isHeader and 0 or 1,
                        BackgroundColor3       = isHeader and theme.Surface or theme.Card,
                        Parent                 = f,
                    })
                    if isHeader then corner(row, R_SM - 2) end
                    for i, col in ipairs(cols) do
                        local cell = type(data) == "table" and (data[col] or data[i] or "") or ""
                        new("TextLabel", {
                            BackgroundTransparency = 1,
                            Position               = UDim2.new((i - 1) * colW, 0, 0, 0),
                            Size                   = UDim2.new(colW, -4, 1, 0),
                            Font                   = isHeader and FONT_BOLD or FONT_REG,
                            TextSize               = ts(12),
                            TextColor3             = isHeader and theme.Foreground or theme.MutedForeground,
                            TextXAlignment         = Enum.TextXAlignment.Left,
                            TextTruncate           = Enum.TextTruncate.AtEnd,
                            Text                   = tostring(isHeader and col or cell),
                            Parent                 = row,
                        })
                    end
                    return row
                end

                makeRow(nil, true)
                local rowFrames = {}
                local function buildRows()
                    for _, r in ipairs(rowFrames) do r:Destroy() end
                    rowFrames = {}
                    for _, rowData in ipairs(rows) do
                        local r = makeRow(rowData, false)
                        table.insert(rowFrames, r)
                        r.MouseEnter:Connect(function()
                            r.BackgroundTransparency = 0
                            r.BackgroundColor3       = theme.SurfaceElevated
                        end)
                        r.MouseLeave:Connect(function() r.BackgroundTransparency = 1 end)
                    end
                end
                buildRows()

                local api = {}
                function api:SetRows(newRows) rows = newRows or {}; buildRows() end
                function api:AddRow(row)
                    table.insert(rows, row)
                    table.insert(rowFrames, makeRow(row, false))
                end
                function api:Clear()  rows = {}; buildRows() end
                function api:Remove() f:Destroy() end
                return api
            end

            return Tab
        end -- buildTab

        -- ================================================================
        -- Public Win:Tab
        -- ================================================================
        function Win:Tab(name, icon)
            return buildTab(name, icon)
        end

        -- ================================================================
        -- CREDITS TAB (auto-appended)
        -- ================================================================
        local function appendCreditsTab()
            local tab  = buildTab("Credits")
            local page = tab._page
            page.AutomaticCanvasSize = Enum.AutomaticSize.Y

            local cardF = new("Frame", {
