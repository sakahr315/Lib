        -- Open/close keybind
        UserInputService.InputBegan:Connect(function(io, gp)
            if gp then return end
            if io.KeyCode == Enum.KeyCode.RightControl then
                Root.Visible = not Root.Visible
                OpenIcon.Visible = not Root.Visible
