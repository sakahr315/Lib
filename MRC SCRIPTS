                -- search box
                local searchBox = new("TextBox", {
                    Position = UDim2.new(0,12,0,44), Size = UDim2.new(1,-24,0,24),
                    BackgroundColor3 = theme.SurfaceElevated,
                    Font = FONT_REG, TextSize = 12, TextColor3 = theme.Foreground,
