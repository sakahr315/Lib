            -- ============ SLIDER ============
            function Tab:CreateSlider(o)
                o = o or {}
                local min, max = o.Range and o.Range[1] or 0, o.Range and o.Range[2] or 100
                local inc      = o.Increment or 1
                local suffix   = o.Suffix or ""
                local val      = o.CurrentValue or min

                local f = elementCard(54)
                local lbl = new("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 12, 0, 6),
                    Size = UDim2.new(1, -24, 0, 18),
                    Font = FONT_MED, TextSize = 13,
                    TextColor3 = theme.Foreground,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Text = o.Name or "Slider", Parent = f,
                })
                local valLbl = new("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(1, -80, 0, 6),
                    Size = UDim2.new(0, 68, 0, 18),
                    Font = FONT_MED, TextSize = 12,
                    TextColor3 = theme.Primary,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    Text = tostring(val) .. suffix, Parent = f,
                })

                local track = new("Frame", {
                    Position = UDim2.new(0, 12, 1, -18),
                    Size = UDim2.new(1, -24, 0, 6),
                    BackgroundColor3 = theme.SurfaceElevated,
                    BorderSizePixel = 0, Parent = f,
                })
                corner(track, 3)
                local fill = new("Frame", {
                    Size = UDim2.new((val-min)/(max-min), 0, 1, 0),
                    BackgroundColor3 = theme.Primary,
                    BorderSizePixel = 0, Parent = track,
                })
                corner(fill, 3)

                local api = {}
                api.CurrentValue = val
                local function setFromAlpha(a)
                    a = math.clamp(a, 0, 1)
                    local raw = min + (max - min) * a
                    raw = math.floor((raw / inc) + 0.5) * inc
                    raw = math.clamp(raw, min, max)
                    val = raw
                    api.CurrentValue = val
                    valLbl.Text = tostring(val) .. suffix
                    fill.Size = UDim2.new((val-min)/(max-min), 0, 1, 0)
                    if o.Callback then task.spawn(o.Callback, val) end
                end

                local dragging = false
                track.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                        setFromAlpha((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X)
                    end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch then
                        if dragging then dragging = false; saveConfig(Window) end
                    end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
                    or input.UserInputType == Enum.UserInputType.Touch) then
                        setFromAlpha((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X)
                    end
                end)

                function api:Set(v) setFromAlpha((v-min)/(max-min)) end

                if o.Flag then Library.Flags[o.Flag] = api end
                if Window._pendingConfig and o.Flag and Window._pendingConfig[o.Flag] ~= nil then
                    api:Set(Window._pendingConfig[o.Flag])
                end
                return api
            end

