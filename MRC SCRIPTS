-- Executor compatibility (all wrapped, never crash on vanilla)
local function safe(fn) return type(fn) == "function" and fn or function() end end
local _writefile   = safe(rawget(getfenv(), "writefile"))
local _readfile    = rawget(getfenv(), "readfile")    or function() return nil end
local _isfile      = rawget(getfenv(), "isfile")      or function() return false end
local _makefolder  = safe(rawget(getfenv(), "makefolder"))
local _isfolder    = rawget(getfenv(), "isfolder")    or function() return false end
local _setclipboard= safe(rawget(getfenv(), "setclipboard") or rawget(getfenv(), "toclipboard"))
local _gethui      = rawget(getfenv(), "gethui")
local _queueteleport = safe(rawget(getfenv(), "queue_on_teleport") or rawget(getfenv(), "syn_queue_on_teleport"))
local _request     = rawget(getfenv(), "request") or rawget(getfenv(), "http_request") or (syn and syn.request)

local function getParent()
    local ok, hui = pcall(function() return _gethui and _gethui() end)
    if ok and hui then return hui end
    if RunService:IsStudio() then
        return LocalPlayer:WaitForChild("PlayerGui")
    end
    local ok2, cg = pcall(function() return CoreGui end)
    if ok2 and cg then return cg end
    return LocalPlayer:WaitForChild("PlayerGui")
end

