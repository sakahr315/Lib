    if opts.Theme and Themes[opts.Theme] then self.Theme = Themes[opts.Theme] end
    local theme = self.Theme

    local function actuallyBuild()
        -- Loading splash
        if opts.LoadingTitle then
            showLoading(theme, opts.LoadingTitle, opts.LoadingSubtitle, 1.0)
            task.wait(1.15)
        end

        local Window = { Tabs = {}, _config = opts.ConfigurationSaving }

        local Root = new("Frame", {
            Name = "Window",
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(0.5, 0, 0.5, 0),
