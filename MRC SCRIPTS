                NumberSequenceKeypoint.new(0, 0.85),
                NumberSequenceKeypoint.new(0.6, 1),
                NumberSequenceKeypoint.new(1, 1),
            },
            Rotation = 90,
            Parent = Root,
        })

        -- Header
        local Header = new("Frame", {
            Size = UDim2.new(1, 0, 0, 40),
            BackgroundColor3 = theme.Surface,
            BorderSizePixel = 0,
            Parent = Root,
        })
