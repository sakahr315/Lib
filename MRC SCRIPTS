        Font = FONT_REG, TextSize = 13,
        TextColor3 = theme.MutedForeground,
        Text = subtitle or "",
        Parent = box,
    })

    local barBg = new("Frame", {
        AnchorPoint = Vector2.new(0.5, 1),
        Position = UDim2.new(0.5, 0, 1, -20),
        Size = UDim2.new(1, -40, 0, 6),
        BackgroundColor3 = theme.SurfaceElevated,
        BorderSizePixel = 0,
        Parent = box,
    })
    corner(barBg, 4)
    local bar = new("Frame", {
        Size = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = theme.Primary,
        BorderSizePixel = 0,
        Parent = barBg,
    })
    corner(bar, 4)
    tween(bar, TweenInfo.new(duration or 1.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.new(1, 0, 1, 0),
    })

    task.delay((duration or 1.2) + 0.15, function()
        tween(overlay, DEFAULT_TWEEN, { BackgroundTransparency = 1 })
        for _, d in ipairs(overlay:GetDescendants()) do
            if d:IsA("TextLabel") then tween(d, DEFAULT_TWEEN, { TextTransparency = 1 }) end
            if d:IsA("Frame")     then tween(d, DEFAULT_TWEEN, { BackgroundTransparency = 1 }) end
        end
        task.wait(0.25)
        overlay:Destroy()
    end)
end

