function Library:Notify(opts)
    opts = opts or {}
    local theme = self.Theme
    local title    = opts.Title or "Notification"
    local content  = opts.Content or ""
    local duration = opts.Duration or 5
    local image    = opts.Image

    local card = new("Frame", {
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = theme.SurfaceElevated,
        BackgroundTransparency = 0,
        Parent = NotifHolder,
    })
    corner(card, 10)
    stroke(card, theme.Border, 1, 0.88)
    padding(card, 12)

    -- accent stripe
    new("Frame", {
        Size = UDim2.new(0, 3, 1, -16),
        Position = UDim2.new(0, 0, 0, 8),
        BackgroundColor3 = theme.Primary,
        BorderSizePixel = 0,
        Parent = card,
    }).Name = "Stripe"

    local titleLbl = new("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -10, 0, 18),
        Position = UDim2.new(0, 10, 0, 0),
        Font = FONT_BOLD,
        TextSize = 14,
        TextColor3 = theme.Foreground,
        TextXAlignment = Enum.TextXAlignment.Left,
        Text = title,
        Parent = card,
    })

    local body = new("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 10, 0, 22),
        Size = UDim2.new(1, -10, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        Font = FONT_REG,
        TextSize = 13,
        TextColor3 = theme.MutedForeground,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Text = content,
        Parent = card,
    })

    card.BackgroundTransparency = 1
    titleLbl.TextTransparency = 1
    body.TextTransparency = 1
    tween(card, DEFAULT_TWEEN, { BackgroundTransparency = 0 })
    tween(titleLbl, DEFAULT_TWEEN, { TextTransparency = 0 })
    tween(body, DEFAULT_TWEEN, { TextTransparency = 0 })

    task.delay(duration, function()
        tween(card, DEFAULT_TWEEN, { BackgroundTransparency = 1 })
        tween(titleLbl, DEFAULT_TWEEN, { TextTransparency = 1 })
        tween(body, DEFAULT_TWEEN, { TextTransparency = 1 })
        task.wait(0.25)
        card:Destroy()
    end)
end

