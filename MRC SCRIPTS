        function Win:ExportConfig()
            if self._destroyed then return nil end
            local data = { __version = CONFIG_VERSION }
            for flag, ref in pairs(Library.Flags) do
                if ref._saveEnabled ~= false then
                    local ok, val = pcall(function() return ref.Value end)
                    if ok then data[flag] = val end
                end
            end
            local ok, json = pcall(function() return HttpService:JSONEncode(data) end)
            return ok and json or nil
        end

        function Win:ImportConfig(json)
            if self._destroyed or type(json) ~= "string" then return false end
            local ok, data = pcall(function() return HttpService:JSONDecode(json) end)
            if not ok or type(data) ~= "table" then return false end
            for flag, val in pairs(data) do
                if flag ~= "__version" and Library.Flags[flag] then
                    pcall(function() Library.Flags[flag]:Set(val) end)
                end
            end
            return true
        end

        -- ================================================================
        -- TAB factory
        -- ================================================================
        local function buildTab(name, tabIcon)
            local Tab = { _win = Win }

            -- CHANGE: tab button — larger text, more spacing, no background by default
            local TabBtn = new("TextButton", {
                Size                   = UDim2.new(1, 0, 0, 36),
                BackgroundColor3       = theme.SurfaceElevated,
                BackgroundTransparency = 1,
                -- CHANGE: icon support in tab label
                Text                   = tabIcon and (tabIcon .. "  " .. (name or "Tab")) or (name or "Tab"),
                TextXAlignment         = Enum.TextXAlignment.Left,
                Font                   = FONT_MED, TextSize = ts(13),
                TextColor3             = theme.MutedForeground,
                AutoButtonColor        = false,
                Parent                 = SideScroll,
            })
            corner(TabBtn, R_SM)
            pad(TabBtn, nil, 14, 8, 0, 0)

            local TabBar = new("Frame", {
                Position               = UDim2.new(0, 0, 0.5, -10),
                Size                   = UDim2.new(0, 3, 0, 20),
                BackgroundColor3       = theme.Primary,
                BackgroundTransparency = 1,
                BorderSizePixel        = 0,
                Parent                 = TabBtn,
            })

            local _isActive = false

            -- CHANGE: no hover background — only text brightening
            TabBtn.MouseEnter:Connect(function()
                if not _isActive then
                    tw(TabBtn, TI_Q, { TextColor3 = theme.Foreground })
                end
            end)
            TabBtn.MouseLeave:Connect(function()
                if not _isActive then
                    tw(TabBtn, TI_Q, { TextColor3 = theme.MutedForeground })
                end
            end)

            local Page = new("ScrollingFrame", {
                Size                   = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                BorderSizePixel        = 0,
                Visible                = false,
                ScrollBarThickness     = 3,
                ScrollBarImageColor3   = theme.Primary,
                CanvasSize             = UDim2.new(0, 0, 0, 0),
                AutomaticCanvasSize    = Enum.AutomaticSize.Y,
                Parent                 = Pages,
            })
            listL(Page, 10)
            pad(Page, nil, 20, 20, 16, 16)

            new("UIGradient", {
                Transparency = NumberSequence.new{
                    NumberSequenceKeypoint.new(0,    0),
                    NumberSequenceKeypoint.new(0.93, 0),
                    NumberSequenceKeypoint.new(1,    1),
                },
                Rotation = 90,
                Parent   = Page,
            })

            Tab._page       = Page
            Tab._btn        = TabBtn
            Tab._bar        = TabBar
            Tab._isActive   = false
            Tab._scrollPos  = Vector2.new(0, 0)

            local function activate()
                for _, t in ipairs(Win.Tabs) do
                    if t._isActive then
                        t._scrollPos = t._page.CanvasPosition
                    end
                    t._page.Visible = false
                    t._isActive     = false
                    -- CHANGE: inactive tabs go back to zero background + muted text
                    tw(t._btn, TI_Q, {
                        BackgroundTransparency = 1,
                        TextColor3             = theme.MutedForeground,
                    })
                    if t._bar then tw(t._bar, TI_Q, { BackgroundTransparency = 1 }) end
                end
                Page.Visible  = true
                _isActive     = true
                Tab._isActive = true
                Page.CanvasPosition = Tab._scrollPos
