-- FIX #14: clamp drag to viewport bounds
local function makeDraggable(handle, target)
    local dragging, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            dragStart = input.Position
            startPos  = target.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch) then
            local d  = input.Position - dragStart
            local vp = workspace.CurrentCamera.ViewportSize
            local sw = target.AbsoluteSize.X
            local sh = target.AbsoluteSize.Y
            local nx = math.clamp(startPos.X.Offset + d.X, 0, vp.X - sw)
            local ny = math.clamp(startPos.Y.Offset + d.Y, 0, vp.Y - sh)
            target.Position = UDim2.new(startPos.X.Scale, nx, startPos.Y.Scale, ny)
        end
    end)
end

local function safeCallback(fn, notifyFn)
    if type(fn) ~= "function" then return function() end end
    return function(...)
        local ok, err = pcall(fn, ...)
        if not ok then
            notifyFn({ Title = "Callback Error", Content = tostring(err), Type = "error", Duration = 8 })
        end
    end
end

local function hsvToColor(h, s, v) return Color3.fromHSV(h, s, v) end
local function colorToHsv(c)       return Color3.toHSV(c) end

local function debounce(fn, delay)
    local thread
    return function(...)
        local args = { ... }
        if thread then task.cancel(thread) end
        thread = task.delay(delay, function() thread = nil; fn(table.unpack(args)) end)
    end
end

