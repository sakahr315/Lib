                    tw(f,         TI_Q, { Size = UDim2.new(1, 0, 0, 52) })
                    tw(list,      TI_Q, { Size = UDim2.new(1, -32, 0, 0) })
                    tw(searchBox, TI_Q, { BackgroundTransparency = 1 })
