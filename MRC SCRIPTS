                kbBtn.MouseButton1Click:Connect(function()
                    listening  = true
                    kbBtn.Text = "…"
                    tw(kbBtn, TI_Q, { BackgroundColor3 = theme.Primary, TextColor3 = theme.PrimaryForeground })
                end)

                local unlisten = routerListen("_began", function(input, gp)
