local _tipConn
local function showTooltip(text)
    if not text or text == "" then return end
    TooltipLbl.Text = text
    Tooltip.Visible = true
    tw(Tooltip,    TI_Q, { BackgroundTransparency = 0 })
    tw(TooltipLbl, TI_Q, { TextTransparency = 0 })
    if _tipConn then _tipConn:Disconnect() end
    local function follow()
        local mp = UIS:GetMouseLocation()
        Tooltip.Position = UDim2.new(0, mp.X + 14, 0, mp.Y + 18)
    end
    follow()
    _tipConn = RunService.RenderStepped:Connect(follow)
end

local function hideTooltip()
    if _tipConn then _tipConn:Disconnect(); _tipConn = nil end
    tw(Tooltip,    TI_Q, { BackgroundTransparency = 1 })
    tw(TooltipLbl, TI_Q, { TextTransparency = 1 })
    task.delay(0.15, function()
        if Tooltip.BackgroundTransparency >= 1 then Tooltip.Visible = false end
    end)
end

local function attachTooltip(frame, text)
    if not text or text == "" then return end
    local current = text
    frame.MouseEnter:Connect(function() showTooltip(current) end)
    frame.MouseLeave:Connect(hideTooltip)
    return function(newText) current = newText end
end

-- =========================================================================
-- 6c. CHAINABLE API DECORATOR
-- =========================================================================
local function decorate(api, frame, opts)
    opts = opts or {}

    local _tipSet = attachTooltip(frame, opts.Tooltip)
    function api:SetTooltip(t)
        if _tipSet then _tipSet(t)
        else _tipSet = attachTooltip(frame, t) end
        return self
    end

    function api:SetVisible(v) frame.Visible = v and true or false; return self end

    function api:SetEnabled(v)
        frame.Active = v and true or false
        for _, d in ipairs(frame:GetDescendants()) do
            if d:IsA("TextButton") or d:IsA("TextBox") then
                d.Active          = v and true or false
                d.AutoButtonColor = false
            end
            if d:IsA("TextLabel") then
                tw(d, TI_Q, { TextTransparency = v and 0 or 0.5 })
            end
        end
        return self
    end

    function api:GetFrame() return frame end

    local function chain(name, alias)
        if type(api[name]) == "function" and not api[alias] then
            api[alias] = function(self, fn)
                api[name](self, fn)
                return self
            end
        end
    end
    chain("OnClick",   "ConnectClick")
    chain("OnHover",   "ConnectHover")
    chain("OnChanged", "ConnectChanged")
    chain("OnPressed", "ConnectPressed")

    return api
end

