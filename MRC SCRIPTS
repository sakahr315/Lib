local function runKeySystem(settings, onPass)
    settings = settings or {}
    local theme = Library.Theme
    local keys  = settings.Key or {"Hello"}
    if type(keys) == "string" then keys = { keys } end
    local title    = settings.Title or "Key System"
    local subtitle = settings.Subtitle or "Enter the key to continue"
    local note     = settings.Note or ""
    local saveKey  = settings.SaveKey
    local fileName = settings.FileName or "CyanUI_Key"
    local grabLink = settings.GrabKeyFromSite

    -- check saved key
    if saveKey and _isfile(fileName .. ".txt") then
        local stored = _readfile(fileName .. ".txt")
        for _, k in ipairs(keys) do
            if stored == k then onPass() return end
        end
    end

    local overlay = new("Frame", {
        Size = UDim2.new(1,0,1,0),
        BackgroundColor3 = theme.Background,
        BackgroundTransparency = 0.1,
        ZIndex = 2000,
        Parent = ScreenGui,
    })

    local box = new("Frame", {
        AnchorPoint = Vector2.new(0.5,0.5),
        Position = UDim2.new(0.5,0,0.5,0),
        Size = UDim2.new(0, 360, 0, 220),
        BackgroundColor3 = theme.Surface,
        Parent = overlay,
    })
    corner(box, 12); stroke(box, theme.Border, 1, 0.88)

    new("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 16, 0, 14),
        Size = UDim2.new(1, -32, 0, 24),
        Font = FONT_BOLD, TextSize = 18,
        TextColor3 = theme.Foreground,
        TextXAlignment = Enum.TextXAlignment.Left,
        Text = title, Parent = box,
    })
    new("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 16, 0, 40),
        Size = UDim2.new(1, -32, 0, 18),
        Font = FONT_REG, TextSize = 13,
        TextColor3 = theme.MutedForeground,
        TextXAlignment = Enum.TextXAlignment.Left,
        Text = subtitle, Parent = box,
    })
    new("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 16, 0, 60),
        Size = UDim2.new(1, -32, 0, 30),
        Font = FONT_REG, TextSize = 12,
        TextColor3 = theme.MutedForeground,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Text = note, Parent = box,
    })

    local input = new("TextBox", {
        Position = UDim2.new(0, 16, 0, 100),
        Size = UDim2.new(1, -32, 0, 36),
        BackgroundColor3 = theme.SurfaceElevated,
        Font = FONT_REG, TextSize = 14,
        TextColor3 = theme.Foreground,
        PlaceholderText = "Enter key…",
        PlaceholderColor3 = theme.MutedForeground,
        ClearTextOnFocus = false,
        Text = "", Parent = box,
    })
    corner(input, 8); stroke(input, theme.Border, 1, 0.9)
    padding(input, nil, 10, 10, 0, 0)

    local function makeBtn(text, x, w, color, fg)
        local b = new("TextButton", {
            Position = UDim2.new(0, x, 1, -52),
            Size = UDim2.new(0, w, 0, 36),
            BackgroundColor3 = color,
            TextColor3 = fg,
            Font = FONT_MED, TextSize = 13,
            Text = text, AutoButtonColor = false,
            Parent = box,
        })
        corner(b, 8)
        b.MouseEnter:Connect(function() tween(b, QUICK_TWEEN, { BackgroundColor3 = theme.PrimaryGlow }) end)
        b.MouseLeave:Connect(function() tween(b, QUICK_TWEEN, { BackgroundColor3 = color }) end)
        return b
    end

    local checkBtn = makeBtn("Check", 16, 110, theme.Primary, theme.PrimaryForeground)
    local copyBtn  = grabLink and makeBtn("Get Key", 134, 110, theme.SurfaceElevated, theme.Foreground)
    local quitBtn  = makeBtn("Cancel", 360 - 16 - 90, 90, theme.SurfaceElevated, theme.Foreground)

    if copyBtn then
        copyBtn.MouseButton1Click:Connect(function()
            _setclipboard(grabLink)
            Library:Notify({ Title = "Key link copied", Content = grabLink, Duration = 4 })
        end)
    end
    quitBtn.MouseButton1Click:Connect(function() overlay:Destroy() end)
    checkBtn.MouseButton1Click:Connect(function()
        local v = input.Text
        for _, k in ipairs(keys) do
            if v == k then
                if saveKey then pcall(_writefile, fileName .. ".txt", v) end
                overlay:Destroy()
                onPass()
                return
            end
        end
        Library:Notify({ Title = "Invalid Key", Content = "That key didn't match.", Duration = 4 })
        tween(input, QUICK_TWEEN, { BackgroundColor3 = theme.Destructive })
        task.delay(0.4, function() tween(input, QUICK_TWEEN, { BackgroundColor3 = theme.SurfaceElevated }) end)
    end)
end

-- =========================================================================
-- 8. CONFIG SAVING
-- =========================================================================
local function configPath(folder, file)
    return (folder and (folder .. "/") or "") .. file .. ".json"
end

local function saveConfig(window)
    local cfg = window._config
    if not (cfg and cfg.Enabled) then return end
    local data = {}
    for flag, ref in pairs(Library.Flags) do
        local ok, val = pcall(function() return ref.CurrentValue end)
        if ok then data[flag] = val end
    end
    pcall(function()
        if cfg.FolderName and not _isfolder(cfg.FolderName) then _makefolder(cfg.FolderName) end
        _writefile(configPath(cfg.FolderName, cfg.FileName or "Config"),
                   HttpService:JSONEncode(data))
    end)
end

local function loadConfig(window)
    local cfg = window._config
    if not (cfg and cfg.Enabled) then return end
    local path = configPath(cfg.FolderName, cfg.FileName or "Config")
    if not _isfile(path) then return end
    local ok, txt = pcall(_readfile, path)
    if not ok or not txt then return end
    local ok2, data = pcall(function() return HttpService:JSONDecode(txt) end)
    if not ok2 or type(data) ~= "table" then return end
    window._pendingConfig = data
end

