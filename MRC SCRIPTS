                Font                   = FONT_REG, TextSize = ts(10),
                TextColor3             = theme.MutedForeground,
                Text                   = "MRC UI is free software. Use responsibly.",
                Parent                 = page,
            })
        end

        appendCreditsTab()

        -- ================================================================
        -- Post-build
        -- ================================================================
        table.insert(Library.Windows, Win)
        loadConfig(Win)

        if opts.Discord and opts.Discord.Enabled and opts.Discord.Invite then
            task.delay(0.5, function()
                _setclipboard("https://discord.gg/" .. opts.Discord.Invite)
                Library:Notify({
                    Title    = "Discord",
                    Content  = "discord.gg/" .. opts.Discord.Invite .. " copied to clipboard.",
                    Type     = "info",
                    Duration = 6,
                })
            end)
        end

        return Win
    end -- build()

    if opts.KeySystem then
        local result
        runKeySystem(opts.KeySettings or {}, function()
            result = build()
        end, notifyFn)
        while not result do task.wait(0.05) end
        return result
    end

    return build()
end -- Library:Window

return Library
