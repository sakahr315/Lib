                if opts2.MaxLength then
                    box.MaxVisibleGraphemes = opts2.MaxLength
                    box:GetPropertyChangedSignal("Text"):Connect(function()
                        if #box.Text > opts2.MaxLength then
                            box.Text = box.Text:sub(1, opts2.MaxLength)
                        end
                    end)
                end

                box.Focused:Connect(function()
                    tw(boxStroke, TI_Q, { Color = theme.Primary, Transparency = 0.5 })
                end)
                box.FocusLost:Connect(function()
                    tw(boxStroke, TI_Q, { Color = theme.Border, Transparency = 0.96 })
                end)

                local changed = Signal.new()
                local api     = {}
                api._saveEnabled = opts2.Save ~= false
                api.Value        = box.Text

                local function fire()
                    api.Value = box.Text; changed:Fire(box.Text); Win._debouncedSave()
                end
                box.FocusLost:Connect(function()
                    if opts2.Numeric then box.Text = tostring(tonumber(box.Text) or 0) end
                    fire()
                    if opts2.ClearOnSubmit then box.Text = "" end
                end)

                function api:Set(v)        box.Text = tostring(v); fire() end
                function api:OnChanged(fn) return changed:Connect(safeCallback(fn, notifyFn)) end
                if opts2.Flag then Library.Flags[opts2.Flag] = api end
                if Win._pendingConfig and opts2.Flag and Win._pendingConfig[opts2.Flag] ~= nil then
                    api:Set(Win._pendingConfig[opts2.Flag])
                end
                if Win._pendingConfig and opts2.Flag then
                    Win._pendingConfig[opts2.Flag] = nil
                end
                return decorate(api, f, opts2)
            end

