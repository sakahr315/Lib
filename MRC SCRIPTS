                Font                   = FONT_REG, TextSize = ts(12),
                TextColor3             = theme.MutedForeground,
                Text                   = "Made by  mrc__s",
                Parent                 = cardF,
            })

            new("Frame", {
                AnchorPoint            = Vector2.new(0.5, 0),
                Position               = UDim2.new(0.5, 0, 0, 146),
                Size                   = UDim2.new(0.7, 0, 0, 1),
                BackgroundColor3       = theme.Border,
                BackgroundTransparency = 0.88,
                BorderSizePixel        = 0,
                Parent                 = cardF,
            })

            new("TextLabel", {
                BackgroundTransparency = 1,
                Position               = UDim2.new(0, 0, 0, 154),
                Size                   = UDim2.new(1, 0, 0, 14),
                Font                   = FONT_MED, TextSize = ts(11),
                TextColor3             = theme.MutedForeground,
                Text                   = "discord.gg/YV3GjGw3PY",
                Parent                 = cardF,
            })

            local copyBtn = new("TextButton", {
                AnchorPoint      = Vector2.new(0.5, 0),
                Position         = UDim2.new(0.5, 0, 0, 176),
                Size             = UDim2.new(0, 140, 0, 30),
                BackgroundColor3 = theme.Accent,
                TextColor3       = theme.Primary,
                Font             = FONT_MED, TextSize = ts(12),
                Text             = "Copy Invite Link",
                AutoButtonColor  = false,
                BorderSizePixel  = 0,
                Parent           = cardF,
            })
            corner(copyBtn, R_MD)
            stroke(copyBtn, theme.Primary, 1, 0.70)
            copyBtn.MouseEnter:Connect(function()
                tw(copyBtn, TI_Q, { BackgroundColor3 = theme.Primary, TextColor3 = theme.PrimaryForeground })
            end)
            copyBtn.MouseLeave:Connect(function()
                tw(copyBtn, TI_Q, { BackgroundColor3 = theme.Accent, TextColor3 = theme.Primary })
            end)
            copyBtn.MouseButton1Click:Connect(function()
                _setclipboard("https://discord.gg/YV3GjGw3PY")
                notifyFn({
                    Title    = "Copied!",
                    Content  = "discord.gg/YV3GjGw3PY copied to clipboard.",
                    Type     = "success",
                    Duration = 4,
                })
                tw(copyBtn, TI_Q, { BackgroundColor3 = theme.Success })
                task.delay(0.8, function()
                    tw(copyBtn, TI_Q, { BackgroundColor3 = theme.Accent })
                end)
            end)

            new("TextLabel", {
                BackgroundTransparency = 1,
                AnchorPoint            = Vector2.new(0.5, 0),
