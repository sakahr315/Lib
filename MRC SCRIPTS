--- Create a new CyanUI window.
--- @param opts { Title:string, LoadingTitle:string?, LoadingSubtitle:string?, Theme:string?, KeySystem:boolean?, KeySettings:table?, Discord:table?, ConfigurationSaving:table? }
--- @return Window
function Library:Window(opts)
    opts = opts or {}
    if opts.Theme and Themes[opts.Theme] then self.Theme = Themes[opts.Theme] end
    local theme = self.Theme

    local notifyFn = function(o) self:Notify(o) end

    local function build()
        if opts.LoadingTitle then
            showLoading(theme, opts.LoadingTitle, opts.LoadingSubtitle, 1.0)
            task.wait(1.15)
        end

        --- @class Window
        local Win = {
            Tabs          = {},
            _config       = opts.ConfigurationSaving,
            _connections  = {},  -- all UIS connections to clean up
            _themeUnreg   = nil,
        }

        -- debounced save
        Win._debouncedSave = debounce(function() saveConfig(Win) end, 0.5)

        -- Root frame
        local Root = new("Frame", {
            Name             = "Window",
            AnchorPoint      = Vector2.new(0.5, 0.5),
            Position         = UDim2.new(0.5, 0, 0.5, 0),
            Size             = UDim2.new(0, 580, 0, 390),
            BackgroundColor3 = theme.Background,
            ClipsDescendants = true,
            Parent           = ScreenGui,
        })
        corner(Root, 14); stroke(Root, theme.Border, 1, 0.88)
        Win.Root = Root

        new("UIGradient", {
            Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, theme.Primary),
                ColorSequenceKeypoint.new(1, theme.Background),
            },
            Transparency = NumberSequence.new{
                NumberSequenceKeypoint.new(0, 0.85),
                NumberSequenceKeypoint.new(0.6, 1),
                NumberSequenceKeypoint.new(1,   1),
            },
            Rotation = 90,
            Parent = Root,
        })

        -- Header
        local Header = new("Frame", {
            Size             = UDim2.new(1, 0, 0, 42),
            BackgroundColor3 = theme.Surface,
            BorderSizePixel  = 0,
            Parent           = Root,
        })
        new("Frame", {
            Position = UDim2.new(0,0,1,-1), Size = UDim2.new(1,0,0,1),
            BackgroundColor3 = theme.Border, BackgroundTransparency = 0.88,
            BorderSizePixel = 0, Parent = Header,
        })
        local titleLbl = new("TextLabel", {
            BackgroundTransparency = 1,
            Position  = UDim2.new(0,14,0,0), Size = UDim2.new(1,-120,1,0),
            Font      = FONT_BOLD, TextSize = 14,
            TextColor3 = theme.Foreground, Text = opts.Title or "CyanUI",
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = Header,
        })

        local function ctrlBtn(icon, xOff, hoverCol)
            local b = new("TextButton", {
                Size = UDim2.new(0,22,0,22),
                Position = UDim2.new(1, xOff, 0.5, -11),
                BackgroundColor3 = theme.SurfaceElevated,
                Text = icon, Font = FONT_BOLD, TextSize = 13,
                TextColor3 = theme.Foreground, AutoButtonColor = false,
                Parent = Header,
            })
            corner(b, 6)
            b.MouseEnter:Connect(function() tw(b, TI_Q, { BackgroundColor3 = hoverCol }) end)
            b.MouseLeave:Connect(function() tw(b, TI_Q, { BackgroundColor3 = theme.SurfaceElevated }) end)
            return b
        end
        local closeBtn = ctrlBtn("×", -32, theme.Destructive)
        local minBtn   = ctrlBtn("–", -62, theme.Primary)

        makeDraggable(Header, Root)

        -- Sidebar
        local Sidebar = new("Frame", {
            Position = UDim2.new(0,0,0,42), Size = UDim2.new(0,155,1,-42),
            BackgroundColor3 = theme.Sidebar, BorderSizePixel = 0, Parent = Root,
        })
        new("Frame", {
            Position = UDim2.new(1,-1,0,0), Size = UDim2.new(0,1,1,0),
            BackgroundColor3 = theme.Border, BackgroundTransparency = 0.88,
            BorderSizePixel = 0, Parent = Sidebar,
        })
        local SideScroll = new("ScrollingFrame", {
            Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1,
            BorderSizePixel = 0, ScrollBarThickness = 2,
            ScrollBarImageColor3 = theme.Primary,
            CanvasSize = UDim2.new(0,0,0,0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            Parent = Sidebar,
        })
        listL(SideScroll, 4); pad(SideScroll, 8)

        -- Scroll fade overlay on sidebar
        new("UIGradient", {
            Transparency = NumberSequence.new{
                NumberSequenceKeypoint.new(0,   0),
                NumberSequenceKeypoint.new(0.92,0),
                NumberSequenceKeypoint.new(1,   1),
            },
            Rotation = 90,
            Parent   = SideScroll,
        })

        -- Pages
        local Pages = new("Frame", {
            Position = UDim2.new(0,155,0,42), Size = UDim2.new(1,-155,1,-42),
            BackgroundTransparency = 1, Parent = Root,
        })

        -- Open/close icon (shown when window is closed)
        local OpenIcon = new("TextButton", {
            Size = UDim2.new(0,36,0,36), Position = UDim2.new(0,12,0,12),
            BackgroundColor3 = theme.Primary, TextColor3 = theme.PrimaryForeground,
            Font = FONT_BOLD, TextSize = 18, Text = "≡",
            AutoButtonColor = false, Visible = false, Parent = ScreenGui,
        })
        corner(OpenIcon, 10)

        local minimized = false
        minBtn.MouseButton1Click:Connect(function()
            minimized = not minimized
            tw(Root, TI, { Size = minimized and UDim2.new(0,580,0,42) or UDim2.new(0,580,0,390) })
        end)
        closeBtn.MouseButton1Click:Connect(function()
            Root.Visible = false; OpenIcon.Visible = true
        end)
        OpenIcon.MouseButton1Click:Connect(function()
            Root.Visible = true; OpenIcon.Visible = false
        end)

        -- RightControl to toggle
        local rcConn = routerListen("_began", function(input, gp)
            if gp then return end
            if input.UserInputType == Enum.UserInputType.Keyboard
            and input.KeyCode == Enum.KeyCode.RightControl then
                Root.Visible   = not Root.Visible
                OpenIcon.Visible = not Root.Visible
            end
        end)
        table.insert(Win._connections, rcConn)

        -- intro anim
        Root.Size = UDim2.new(0,480,0,320)
        Root.BackgroundTransparency = 1
        tw(Root, TI, { Size = UDim2.new(0,580,0,390), BackgroundTransparency = 0 })

        -- Theme listener
        Win._themeUnreg = Library:OnThemeChanged(function(t)
            -- update root colours
            tw(Root,    TI, { BackgroundColor3 = t.Background })
            tw(Header,  TI, { BackgroundColor3 = t.Surface })
            tw(Sidebar, TI, { BackgroundColor3 = t.Sidebar })
            titleLbl.TextColor3 = t.Foreground
        end)

        -- ================================================================
        -- Window methods
        -- ================================================================

        --- Destroy the window and clean up all connections.
        function Win:Destroy()
            saveConfig(self)
            for _, unlisten in ipairs(self._connections) do unlisten() end
            if self._themeUnreg then self._themeUnreg() end
            Root:Destroy(); OpenIcon:Destroy()
        end

        --- @param t string
        function Win:SetTitle(t) titleLbl.Text = t end

        -- ================================================================
        -- TAB
        -- ================================================================
        --- Create a new tab.
        --- @param name string
        --- @return Tab
        function Win:Tab(name)
            --- @class Tab
            local Tab = { _win = self }

            local TabBtn = new("TextButton", {
                Size = UDim2.new(1,0,0,32),
                BackgroundColor3 = theme.Sidebar,
                BackgroundTransparency = 1,
                Text = "  " .. (name or "Tab"),
                TextXAlignment = Enum.TextXAlignment.Left,
                Font = FONT_MED, TextSize = 13,
                TextColor3 = theme.MutedForeground,
                AutoButtonColor = false,
                Parent = SideScroll,
            })
            corner(TabBtn, 8); pad(TabBtn, nil, 10, 8, 0, 0)

            local Page = new("ScrollingFrame", {
                Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1,
                BorderSizePixel = 0, Visible = false,
                ScrollBarThickness = 3,
                ScrollBarImageColor3 = theme.Primary,
                CanvasSize = UDim2.new(0,0,0,0),
                AutomaticCanvasSize = Enum.AutomaticSize.Y,
                Parent = Pages,
            })
            listL(Page, 8); pad(Page, 14)

            -- scroll fade
            new("UIGradient", {
                Transparency = NumberSequence.new{
                    NumberSequenceKeypoint.new(0,   0),
                    NumberSequenceKeypoint.new(0.93, 0),
                    NumberSequenceKeypoint.new(1,   1),
                },
                Rotation = 90,
                Parent   = Page,
            })

            Tab._page = Page
            Tab._btn  = TabBtn

            local function activate()
                for _, t in ipairs(self.Tabs) do
                    t._page.Visible = false
                    tw(t._btn, TI_Q, {
                        BackgroundTransparency = 1,
                        TextColor3 = theme.MutedForeground,
                    })
                end
                Page.Visible = true
                tw(TabBtn, TI_Q, {
                    BackgroundColor3 = theme.SurfaceElevated,
                    BackgroundTransparency = 0,
                    TextColor3 = theme.Foreground,
                })
            end
            TabBtn.MouseButton1Click:Connect(activate)
            table.insert(self.Tabs, Tab)
            if #self.Tabs == 1 then activate() end

            -- ============================================================
            -- Shared element helpers scoped to this Tab
            -- ============================================================
            local function card(height)
                local f = new("Frame", {
                    Size = UDim2.new(1,0,0,height or 38),
                    BackgroundColor3 = theme.Card,
                    Parent = Page,
                })
                corner(f, 8); stroke(f, theme.Border, 1, 0.90)
                return f
            end

            --- Attach a context menu to any frame element.
            --- @param frame Frame
            --- @param items { Label:string, Icon:string?, Callback:function? }[]
            local function attachCtx(frame, items)
                if not items or #items == 0 then return end
                frame.InputBegan:Connect(function(input)
                    if input.UserInputType ~= Enum.UserInputType.MouseButton2 then return end
                    -- clear old items
                    for _, c in ipairs(CtxList:GetChildren()) do
                        if c:IsA("TextButton") then c:Destroy() end
                    end
                    CtxMenu.BackgroundColor3 = theme.SurfaceElevated
                    local itemH = 28
                    for _, item in ipairs(items) do
                        local b = new("TextButton", {
                            Size = UDim2.new(1,0,0,itemH),
                            BackgroundTransparency = 1,
                            BackgroundColor3 = theme.Card,
                            Font = FONT_MED, TextSize = 12,
                            TextColor3 = theme.Foreground,
                            TextXAlignment = Enum.TextXAlignment.Left,
                            Text = "  " .. (item.Icon and (item.Icon .. "  ") or "") .. (item.Label or ""),
                            AutoButtonColor = false,
                            Parent = CtxList,
                        })
                        corner(b, 4)
                        b.MouseEnter:Connect(function()
                            tw(b, TI_Q, { BackgroundTransparency = 0 })
                        end)
                        b.MouseLeave:Connect(function()
                            tw(b, TI_Q, { BackgroundTransparency = 1 })
                        end)
                        b.MouseButton1Click:Connect(function()
                            hideCtx()
                            if item.Callback then
                                safeCallback(item.Callback, notifyFn)()
                            end
                        end)
                    end
                    local totalH = #items * itemH + 8
                    local mp = UIS:GetMouseLocation()
                    CtxMenu.Position = UDim2.new(0, mp.X + 4, 0, mp.Y + 4)
                    CtxMenu.Visible  = true
                    ctxOpen          = true
                    tw(CtxMenu, TI_Q, { Size = UDim2.new(0,160,0,totalH) })
                end)
            end

            -- ============================================================
            -- SECTION
            -- ============================================================
            --- @param name string
            function Tab:Section(name)
                local container = new("Frame", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1,0,0,22),
                    Parent = Page,
                })
                new("Frame", {
                    AnchorPoint = Vector2.new(0,0.5), Position = UDim2.new(0,0,0.5,0),
                    Size = UDim2.new(0.3,0,0,1), BackgroundColor3 = theme.Primary,
                    BackgroundTransparency = 0.7, BorderSizePixel = 0, Parent = container,
                })
                local lbl = new("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1,0,1,0),
                    Font = FONT_BOLD, TextSize = 11,
                    TextColor3 = theme.Primary,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Text = string.upper(name or "Section"),
                    Parent = container,
                })
                new("Frame", {
                    AnchorPoint = Vector2.new(1,0.5), Position = UDim2.new(1,0,0.5,0),
                    Size = UDim2.new(0.3,0,0,1), BackgroundColor3 = theme.Primary,
                    BackgroundTransparency = 0.7, BorderSizePixel = 0, Parent = container,
                })
                return {
                    Set    = function(_, t) lbl.Text = string.upper(t) end,
                    Remove = function()    container:Destroy() end,
                }
            end

            -- ============================================================
            -- BUTTON
            -- ============================================================
            --- @param opts { Label:string, Description:string?, ContextMenu:table? }
            --- @return ButtonElement
            function Tab:Button(opts)
                opts = opts or {}
                local f  = card(40)
                local lbl = new("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1,-12,0,18),
                    Position = UDim2.new(0,12,0,opts.Description and 5 or 0),
                    Font = FONT_MED, TextSize = 13,
                    TextColor3 = theme.Foreground,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Text = opts.Label or "Button",
                    Parent = f,
                })
                if opts.Description then
                    new("TextLabel", {
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1,-12,0,14),
                        Position = UDim2.new(0,12,0,22),
                        Font = FONT_REG, TextSize = 11,
                        TextColor3 = theme.MutedForeground,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Text = opts.Description,
                        Parent = f,
                    })
                    f.Size = UDim2.new(1,0,0,46)
                end

                local clicked = Signal.new()
                local hover   = Signal.new()

                local btn = new("TextButton", {
                    Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1,
                    Text = "", Parent = f,
                })
                btn.MouseEnter:Connect(function()
                    tw(f, TI_Q, { BackgroundColor3 = theme.SurfaceElevated })
                    hover:Fire(true)
                end)
                btn.MouseLeave:Connect(function()
                    tw(f, TI_Q, { BackgroundColor3 = theme.Card })
                    hover:Fire(false)
                end)
                btn.MouseButton1Click:Connect(function()
                    tw(f, TI_Q, { BackgroundColor3 = theme.Primary })
                    task.delay(0.12, function() tw(f, TI_Q, { BackgroundColor3 = theme.Card }) end)
                    clicked:Fire()
                end)

                if opts.ContextMenu then attachCtx(f, opts.ContextMenu) end

                --- @class ButtonElement
                local api = {}
                api._saveEnabled = opts.Save ~= false

                --- Connect a click handler.
                --- @param fn function
                --- @return Connection
                function api:OnClick(fn)
                    return clicked:Connect(safeCallback(fn, notifyFn))
                end

                --- Connect a hover handler; receives true on enter, false on leave.
                --- @param fn function
                --- @return Connection
                function api:OnHover(fn)
                    return hover:Connect(safeCallback(fn, notifyFn))
                end

                --- @param text string
                function api:SetLabel(text)  lbl.Text = text end
                function api:Remove()        f:Destroy() end
                return api
            end

            -- ============================================================
            -- LABEL
            -- ============================================================
            function Tab:Label(text)
                local f   = card(32)
                f.BackgroundColor3 = theme.Surface
                local lbl = new("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1,0,1,0),
                    Font = FONT_REG, TextSize = 13,
                    TextColor3 = theme.Foreground,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Text = text or "Label",
                    Parent = f,
                })
                pad(lbl, nil, 12, 12, 0, 0)
                return {
                    Set    = function(_, t) lbl.Text = t end,
                    Remove = function()     f:Destroy() end,
                }
            end

            -- ============================================================
            -- PARAGRAPH
            -- ============================================================
            function Tab:Paragraph(opts)
                opts = opts or {}
                local f = card(56)
                f.AutomaticSize = Enum.AutomaticSize.Y
                pad(f, 10); listL(f, 4)
                local title = new("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1,0,0,18),
                    Font = FONT_BOLD, TextSize = 13,
                    TextColor3 = theme.Foreground,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Text = opts.Title or "Title", Parent = f,
                })
                local body = new("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1,0,0,0),
                    AutomaticSize = Enum.AutomaticSize.Y,
                    Font = FONT_REG, TextSize = 12,
                    TextColor3 = theme.MutedForeground,
                    TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left,
                    Text = opts.Content or "", Parent = f,
                })
                return {
                    Set = function(_, t)
                        if type(t) == "table" then
                            if t.Title   then title.Text = t.Title   end
                            if t.Content then body.Text  = t.Content end
                        else body.Text = t end
                    end,
                    Remove = function() f:Destroy() end,
                }
            end

            -- ============================================================
            -- DIVIDER
            -- ============================================================
            function Tab:Divider()
                local d = new("Frame", {
                    Size = UDim2.new(1,0,0,1),
                    BackgroundColor3 = theme.Border,
                    BackgroundTransparency = 0.85,
                    BorderSizePixel = 0, Parent = Page,
                })
                return { Remove = function() d:Destroy() end }
            end

            -- ============================================================
            -- TOGGLE
            -- ============================================================
            --- @param opts { Label:string, Description:string?, Default:boolean?, Flag:string?, Save:boolean?, ContextMenu:table? }
            function Tab:Toggle(opts)
                opts  = opts or {}
                local state = opts.Default or false
                local f     = card(opts.Description and 46 or 40)
                local lbl = new("TextLabel", {
                    BackgroundTransparency = 1,
                    Size     = UDim2.new(1,-60,0,18),
                    Position = UDim2.new(0,12,0,opts.Description and 5 or 0),
                    Font = FONT_MED, TextSize = 13,
                    TextColor3 = theme.Foreground,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Text = opts.Label or "Toggle", Parent = f,
                })
                if opts.Description then
                    new("TextLabel", {
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1,-60,0,14),
                        Position = UDim2.new(0,12,0,22),
                        Font = FONT_REG, TextSize = 11,
                        TextColor3 = theme.MutedForeground,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Text = opts.Description, Parent = f,
                    })
                end
                local track = new("Frame", {
                    AnchorPoint = Vector2.new(1,0.5),
                    Position    = UDim2.new(1,-10,0.5,0),
                    Size        = UDim2.new(0,40,0,22),
                    BackgroundColor3 = theme.SurfaceElevated,
                    Parent = f,
                })
                corner(track, 11)
                local knob = new("Frame", {
                    Position = UDim2.new(0,2,0.5,-9), Size = UDim2.new(0,18,0,18),
                    BackgroundColor3 = theme.Foreground, Parent = track,
                })
                corner(knob, 9)

                local changed = Signal.new()
                local api     = {}
                api._saveEnabled = opts.Save ~= false
                api.Value        = state

                local function render()
                    if state then
                        tw(track, TI_Q, { BackgroundColor3 = theme.Primary })
                        tw(knob,  TI_Q, { Position = UDim2.new(1,-20,0.5,-9) })
                    else
                        tw(track, TI_Q, { BackgroundColor3 = theme.SurfaceElevated })
                        tw(knob,  TI_Q, { Position = UDim2.new(0,2,0.5,-9) })
                    end
                end
                render()

                function api:Set(v)
                    state     = v and true or false
                    api.Value = state
                    render()
                    changed:Fire(state)
                    Win._debouncedSave()
                end

                --- @param fn function  receives boolean
                function api:OnChanged(fn) return changed:Connect(safeCallback(fn, notifyFn)) end

                local btn = new("TextButton", {
                    Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1, Text = "", Parent = f,
                })
                btn.MouseButton1Click:Connect(function() api:Set(not state) end)

                if opts.ContextMenu then attachCtx(f, opts.ContextMenu) end
                if opts.Flag then Library.Flags[opts.Flag] = api end
                if Win._pendingConfig and opts.Flag and Win._pendingConfig[opts.Flag] ~= nil then
                    api:Set(Win._pendingConfig[opts.Flag])
                end
                return api
            end

            -- ============================================================
            -- SLIDER
            -- ============================================================
            --- @param opts { Label:string, Range:number[]?, Increment:number?, Default:number?, Suffix:string?, Flag:string?, Save:boolean? }
            function Tab:Slider(opts)
                opts = opts or {}
                local min    = opts.Range and opts.Range[1] or 0
                local max    = opts.Range and opts.Range[2] or 100
                local inc    = opts.Increment or 1
                local suffix = opts.Suffix or ""
                local val    = opts.Default or min
                local f      = card(54)

                new("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0,12,0,6), Size = UDim2.new(1,-24,0,18),
                    Font = FONT_MED, TextSize = 13,
                    TextColor3 = theme.Foreground,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Text = opts.Label or "Slider", Parent = f,
                })
                local valLbl = new("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(1,-80,0,6), Size = UDim2.new(0,68,0,18),
                    Font = FONT_MED, TextSize = 12,
                    TextColor3 = theme.Primary,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    Text = tostring(val)..suffix, Parent = f,
                })
                local track = new("Frame", {
                    Position = UDim2.new(0,12,1,-18), Size = UDim2.new(1,-24,0,6),
                    BackgroundColor3 = theme.SurfaceElevated,
                    BorderSizePixel  = 0, Parent = f,
                })
                corner(track, 3)
                local fill = new("Frame", {
                    Size = UDim2.new((val-min)/(max-min),0,1,0),
                    BackgroundColor3 = theme.Primary,
                    BorderSizePixel = 0, Parent = track,
                })
                corner(fill, 3)
                -- thumb dot
                local thumb = new("Frame", {
                    AnchorPoint = Vector2.new(0.5,0.5),
                    Position    = UDim2.new((val-min)/(max-min),0,0.5,0),
                    Size        = UDim2.new(0,12,0,12),
                    BackgroundColor3 = theme.Primary,
                    Parent = track, ZIndex = track.ZIndex + 1,
                })
                corner(thumb, 6)

                local changed = Signal.new()
                local api     = {}
                api._saveEnabled = opts.Save ~= false
                api.Value        = val

                local dragging = false
                local function setAlpha(a)
                    a   = math.clamp(a, 0, 1)
                    local raw = min + (max - min) * a
                    raw = math.floor((raw / inc) + 0.5) * inc
                    raw = math.clamp(raw, min, max)
                    val           = raw
                    api.Value     = val
                    valLbl.Text   = tostring(val)..suffix
                    fill.Size     = UDim2.new((val-min)/(max-min),0,1,0)
                    thumb.Position = UDim2.new((val-min)/(max-min),0,0.5,0)
                    changed:Fire(val)
                end

                local unlisten1 = routerListen("_began", function(input)
                    if input.UserInputType ~= Enum.UserInputType.MouseButton1
                    and input.UserInputType ~= Enum.UserInputType.Touch then return end
                    local tp = track.AbsolutePosition
                    local ts = track.AbsoluteSize
                    local mp = input.Position
                    if mp.X >= tp.X and mp.X <= tp.X+ts.X
                    and mp.Y >= tp.Y and mp.Y <= tp.Y+ts.Y then
                        dragging = true
                        setAlpha((mp.X - tp.X) / ts.X)
                    end
                end)
                local unlisten2 = routerListen("_ended", function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch then
                        if dragging then dragging = false; Win._debouncedSave() end
                    end
                end)
                local unlisten3 = routerListen("_changed", function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
                    or input.UserInputType == Enum.UserInputType.Touch) then
                        setAlpha((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X)
                    end
                end)
                table.insert(Win._connections, unlisten1)
                table.insert(Win._connections, unlisten2)
                table.insert(Win._connections, unlisten3)

                function api:Set(v) setAlpha((v-min)/(max-min)) end
                function api:OnChanged(fn) return changed:Connect(safeCallback(fn, notifyFn)) end

                if opts.Flag then Library.Flags[opts.Flag] = api end
                if Win._pendingConfig and opts.Flag and Win._pendingConfig[opts.Flag] ~= nil then
                    api:Set(Win._pendingConfig[opts.Flag])
                end
                return api
            end

