                })
                corner(searchBox, 6); pad(searchBox, nil, 8, 8, 0, 0)

                local list = new("Frame", {
                    Position = UDim2.new(0,12,0,72), Size = UDim2.new(1,-24,0,0),
                    BackgroundColor3 = theme.SurfaceElevated,
                    BorderSizePixel = 0, ClipsDescendants = true, Parent = f,
                })
                corner(list, 6)
                local listLay = listL(list, 0); pad(list, 4)

                local changed = Signal.new()
                local api     = {}
                api._saveEnabled = opts.Save ~= false
                api.Value        = current

                local function labelText()
                    if multi then
                        return (type(current) == "table" and #current > 0)
                            and table.concat(current, ", ") or "None"
                    end
                    return tostring(current or "Select…")
                end

                local opened = false
                local function close()
                    opened = false
                    tw(f,    TI_Q, { Size = UDim2.new(1,0,0,40) })
                    tw(list, TI_Q, { Size = UDim2.new(1,-24,0,0) })
                    tw(searchBox, TI_Q, { BackgroundTransparency = 1 })
                    searchBox.Text = ""
                end

                local function rebuild(filter)
                    filter = filter and string.lower(filter) or ""
                    for _, c in ipairs(list:GetChildren()) do
                        if c:IsA("TextButton") then c:Destroy() end
                    end
                    local visible = 0
                    for _, opt in ipairs(options) do
                        local optStr = tostring(opt)
                        if filter == "" or string.find(string.lower(optStr), filter, 1, true) then
                            visible = visible + 1
                            local item = new("TextButton", {
                                Size = UDim2.new(1,0,0,26),
                                BackgroundTransparency = 1,
                                BackgroundColor3 = theme.Card,
                                Font = FONT_REG, TextSize = 12,
                                TextColor3 = theme.Foreground,
                                TextXAlignment = Enum.TextXAlignment.Left,
                                Text = "  "..optStr, AutoButtonColor = false,
                                Parent = list,
                            })
                            corner(item, 4)
                            item.MouseEnter:Connect(function()
                                tw(item, TI_Q, { BackgroundTransparency = 0 })
                            end)
                            item.MouseLeave:Connect(function()
                                tw(item, TI_Q, { BackgroundTransparency = 1 })
                            end)
                            item.MouseButton1Click:Connect(function()
                                if multi then
                                    current = type(current) == "table" and current or {}
                                    local found
                                    for i, v in ipairs(current) do
                                        if v == opt then found = i; break end
                                    end
                                    if found then table.remove(current, found)
                                    else table.insert(current, opt) end
                                else
                                    current = opt; close()
                                end
                                api.Value  = current
                                valBtn.Text = labelText().."  ▾"
                                changed:Fire(current)
                                Win._debouncedSave()
                            end)
                        end
                    end
                    return visible
                end
                rebuild()
                valBtn.Text = labelText().."  ▾"

                valBtn.MouseButton1Click:Connect(function()
                    opened = not opened
                    if opened then
                        local count  = rebuild(searchBox.Text)
                        local listH  = math.min(count * 26 + 8, 160)
                        tw(f,    TI_Q, { Size = UDim2.new(1,0,0,78+listH) })
                        tw(list, TI_Q, { Size = UDim2.new(1,-24,0,listH) })
                        tw(searchBox, TI_Q, { BackgroundTransparency = 0 })
                    else close() end
                end)

                searchBox:GetPropertyChangedSignal("Text"):Connect(function()
                    if not opened then return end
                    local count = rebuild(searchBox.Text)
                    local listH = math.min(count * 26 + 8, 160)
                    list.Size   = UDim2.new(1,-24,0,listH)
                    f.Size      = UDim2.new(1,0,0,78+listH)
                end)

                function api:Set(v)
                    current    = v
                    api.Value  = v
                    valBtn.Text = labelText().."  ▾"
                end
                function api:Refresh(newOpts, keep)
                    options   = newOpts or {}
                    if not keep then current = multi and {} or options[1] end
                    api.Value  = current
                    valBtn.Text = labelText().."  ▾"
                    rebuild()
                end
                function api:OnChanged(fn) return changed:Connect(safeCallback(fn, notifyFn)) end

                if opts.Flag then Library.Flags[opts.Flag] = api end
                if Win._pendingConfig and opts.Flag and Win._pendingConfig[opts.Flag] ~= nil then
                    api:Set(Win._pendingConfig[opts.Flag])
                end
                return api
            end

