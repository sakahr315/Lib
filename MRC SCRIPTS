                    BackgroundColor3  = Color3.fromRGB(12, 19, 26),
                    Font              = FONT_REG, TextSize = ts(13),
                    TextColor3        = theme.Foreground,
                    PlaceholderText   = opts2.Placeholder or "…",
                    PlaceholderColor3 = theme.MutedForeground,
                    ClearTextOnFocus  = false,
                    Text              = opts2.Default or "",
                    BorderSizePixel   = 0,
                    Parent            = f,
                })
                corner(box, R_SM)
                pad(box, nil, 10, 10, 0, 0)
                -- CHANGE: nearly invisible input border
