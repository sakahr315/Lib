local function ts(size)
    return math.round(size * Library.TextScale)
end

function Library:OnThemeChanged(fn)
    local id = {}
    self._themeListeners[id] = fn
    return function() self._themeListeners[id] = nil end
end

function Library:SetTheme(themeOrName)
    if type(themeOrName) == "string" then
        self.Theme = Themes[themeOrName] or self.Theme
    elseif type(themeOrName) == "table" then
        self.Theme = themeOrName
    end
    for _, fn in pairs(self._themeListeners) do task.spawn(fn, self.Theme) end
end

