-- 9. NOTIFICATIONS
-- =========================================================================
local NOTIF_ICONS  = { success = "✓", warning = "!", error = "✕", info = "i" }
local NOTIF_COLORS = { success = "Success", warning = "Warning", error = "Destructive", info = "Info" }

function Library:Notify(opts)
    opts = opts or {}
    local theme     = self.Theme
    local notifType = opts.Type or "info"
    local accentCol = theme[NOTIF_COLORS[notifType] or "Primary"] or theme.Primary
    local icon      = NOTIF_ICONS[notifType] or "i"
    local duration  = opts.Duration or 5

    if #_notifQueue >= NOTIF_MAX then
        local oldest = table.remove(_notifQueue, 1)
        if oldest and oldest.dismiss then oldest.dismiss() end
    end

    local card = new("Frame", {
        Size                   = UDim2.new(1, 0, 0, 64),
        BackgroundColor3       = theme.SurfaceElevated,
        BackgroundTransparency = 1,
        ClipsDescendants       = true,
        Parent                 = NotifHolder,
    })
    corner(card, R_MD)
    -- Notification gets a slightly more visible border than cards
    stroke(card, theme.Border, 1, 0.82)

    local accentBar = new("Frame", {
        Size                   = UDim2.new(0, 3, 1, 0),
        Position               = UDim2.new(0, 0, 0, 0),
        BackgroundColor3       = accentCol,
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
        ZIndex                 = card.ZIndex + 1,
        Parent                 = card,
    })

    local iconBadge = new("TextLabel", {
        Position               = UDim2.new(0, 14, 0.5, -10),
        Size                   = UDim2.new(0, 20, 0, 20),
        BackgroundColor3       = accentCol,
        BackgroundTransparency = 0.82,
        Font                   = FONT_BOLD, TextSize = ts(11),
        TextColor3             = accentCol,
        TextTransparency       = 1,
        Text                   = icon,
        ZIndex                 = card.ZIndex + 1,
        Parent                 = card,
    })
    corner(iconBadge, R_PILL)

    local titleLbl = new("TextLabel", {
        Position               = UDim2.new(0, 44, 0, 12),
        Size                   = UDim2.new(1, -56, 0, 18),
        BackgroundTransparency = 1,
        Font                   = FONT_MED, TextSize = ts(13),
        TextColor3             = theme.Foreground,
        TextTransparency       = 1,
        TextXAlignment         = Enum.TextXAlignment.Left,
        Text                   = opts.Title or "Notification",
        ZIndex                 = card.ZIndex + 1,
        Parent                 = card,
    })

    local bodyLbl = new("TextLabel", {
        Position               = UDim2.new(0, 44, 0, 33),
        Size                   = UDim2.new(1, -56, 0, 18),
        BackgroundTransparency = 1,
        Font                   = FONT_REG, TextSize = ts(11),
        TextColor3             = theme.MutedForeground,
        TextTransparency       = 1,
        TextWrapped            = true,
        TextXAlignment         = Enum.TextXAlignment.Left,
        Text                   = opts.Content or "",
        ZIndex                 = card.ZIndex + 1,
        Parent                 = card,
    })

    local drain = new("Frame", {
        Position               = UDim2.new(0, 0, 1, -2),
        Size                   = UDim2.new(1, 0, 0, 2),
        BackgroundColor3       = accentCol,
        BackgroundTransparency = 0.45,
        BorderSizePixel        = 0,
        ZIndex                 = card.ZIndex + 2,
        Parent                 = card,
    })

    card.Position = UDim2.new(0, 320, 0, 0)
    tw(card,      TI, { BackgroundTransparency = 0, Position = UDim2.new(0, 0, 0, 0) })
    tw(accentBar, TI, { BackgroundTransparency = 0 })
    tw(iconBadge, TI, { TextTransparency = 0 })
    tw(titleLbl,  TI, { TextTransparency = 0 })
    tw(bodyLbl,   TI, { TextTransparency = 0 })
    tw(drain, TweenInfo.new(duration, Enum.EasingStyle.Linear), { Size = UDim2.new(0, 0, 0, 2) })

    local btn = new("TextButton", {
        Size                   = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text                   = "",
        ZIndex                 = card.ZIndex + 3,
        Parent                 = card,
    })

    local dismissed = false
    local entry     = {}
    local function dismiss()
        if dismissed then return end
        dismissed = true
        for i, e in ipairs(_notifQueue) do
            if e == entry then table.remove(_notifQueue, i); break end
        end
        tw(card, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            { BackgroundTransparency = 1, Position = UDim2.new(0, 320, 0, 0) })
        task.wait(0.2)
        pcall(function() card:Destroy() end)
    end
    entry.dismiss = dismiss
    table.insert(_notifQueue, entry)

    btn.MouseButton1Click:Connect(dismiss)
    task.delay(duration, dismiss)
end

