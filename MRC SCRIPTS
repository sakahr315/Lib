                        listening  = false
                        tw(kbBtn, TI_Q, { BackgroundColor3 = theme.Card, TextColor3 = theme.MutedForeground })
                        Win._debouncedSave()
                        return
                    end
                    if gp then return end
                    if input.UserInputType == Enum.UserInputType.Keyboard
                    and input.KeyCode.Name == api.Value then
                        pressed:Fire(api.Value)
                    end
                end)
                table.insert(Win._connections, unlisten)

