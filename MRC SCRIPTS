local function runKeySystem(opts, onPass, notifyFn)
    opts = opts or {}
    local theme    = Library.Theme
    local keys     = opts.Key or { "Hello" }
    if type(keys) == "string" then keys = { keys } end
    local fileName = opts.FileName or "MRCUI_Key"

    if opts.SaveKey and _isfile(fileName .. ".txt") then
