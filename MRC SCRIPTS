                    Parent                 = f,
                })

                if opts2.Description then
                    lbl.AnchorPoint = Vector2.new(0, 0)
                    lbl.Position    = UDim2.new(0, 16, 0, 10)
                    new("TextLabel", {
                        BackgroundTransparency = 1,
                        Position               = UDim2.new(0, 16, 0, 30),
                        Size                   = UDim2.new(1, -76, 0, 13),
                        Font                   = FONT_REG, TextSize = ts(11),
                        TextColor3             = theme.MutedForeground,
                        TextXAlignment         = Enum.TextXAlignment.Left,
                        Text                   = opts2.Description,
                        Parent                 = f,
                    })
                end

                local glow = new("Frame", {
                    AnchorPoint            = Vector2.new(1, 0.5),
                    Position               = UDim2.new(1, -12, 0.5, 0),
                    Size                   = UDim2.new(0, 50, 0, 30),
                    BackgroundColor3       = theme.Primary,
                    BackgroundTransparency = 1,
                    BorderSizePixel        = 0,
                    Parent                 = f,
                })
                corner(glow, R_PILL)

                local track = new("Frame", {
                    AnchorPoint      = Vector2.new(1, 0.5),
                    Position         = UDim2.new(1, -14, 0.5, 0),
                    Size             = UDim2.new(0, 44, 0, 22),
                    BackgroundColor3 = Color3.fromRGB(38, 50, 64),
                    BorderSizePixel  = 0,
                    Parent           = f,
                })
                corner(track, R_PILL)

                local knob = new("Frame", {
                    Position         = UDim2.new(0, 3, 0.5, -8),
                    Size             = UDim2.new(0, 16, 0, 16),
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    BorderSizePixel  = 0,
                    Parent           = track,
                    ZIndex           = track.ZIndex + 1,
                })
                corner(knob, R_PILL)

                local changed = Signal.new()
                local api     = {}
                api._saveEnabled = opts2.Save ~= false
                api.Value        = state

                local DISABLED_TRACK = Color3.fromRGB(28, 36, 44)

                local function render(animated)
                    local twFn = animated ~= false
                        and function(o, i, p) tw(o, i, p) end
                        or  function(o, _, p) for k, v in pairs(p) do o[k] = v end end

                    if not enabled then
                        twFn(track, TI_Q, { BackgroundColor3 = DISABLED_TRACK })
                        twFn(knob,  TI_Q, { BackgroundColor3 = Color3.fromRGB(80, 90, 100) })
                        twFn(glow,  TI_Q, { BackgroundTransparency = 1 })
                        return
                    end

                    if state then
                        twFn(track, TI_Q,     { BackgroundColor3 = theme.Primary })
                        twFn(knob,  TI_SPRING, { Position = UDim2.new(1, -19, 0.5, -8) })
                        twFn(knob,  TI_Q,     { BackgroundColor3 = Color3.fromRGB(255, 255, 255) })
                        twFn(glow,  TI_Q,     { BackgroundTransparency = 0.80 })
                    else
                        twFn(track, TI_Q,     { BackgroundColor3 = Color3.fromRGB(38, 50, 64) })
                        twFn(knob,  TI_SPRING, { Position = UDim2.new(0, 3, 0.5, -8) })
                        twFn(knob,  TI_Q,     { BackgroundColor3 = Color3.fromRGB(255, 255, 255) })
                        twFn(glow,  TI_Q,     { BackgroundTransparency = 1 })
                    end
                end
                render(false)

                function api:Set(v)
                    if not enabled then return end
                    state     = v and true or false
                    api.Value = state
                    render(true)
                    changed:Fire(state)
                    Win._debouncedSave()
                end

                function api:SetEnabled(v)
                    enabled = v and true or false
                    render(true)
                    local btn_ = f:FindFirstChildWhichIsA("TextButton")
                    if btn_ then btn_.Active = enabled end
                    tw(lbl, TI_Q, { TextTransparency = enabled and 0 or 0.5 })
                    return self
                end

                function api:OnChanged(fn) return changed:Connect(safeCallback(fn, notifyFn)) end

                local btn = new("TextButton", {
                    Size                   = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text                   = "",
                    Parent                 = f,
                })
                btn.MouseButton1Click:Connect(function()
                    if enabled then api:Set(not state) end
                end)

                if opts2.ContextMenu then attachCtx(f, opts2.ContextMenu) end
                if opts2.Flag then Library.Flags[opts2.Flag] = api end
                if Win._pendingConfig and opts2.Flag and Win._pendingConfig[opts2.Flag] ~= nil then
                    api:Set(Win._pendingConfig[opts2.Flag])
                end
                return decorate(api, f, opts2)
            end

            -- ============================================================
            -- SLIDER — CHANGE: value label shows "42 %" with space
            -- ============================================================
            function Tab:Slider(opts2)
                opts2 = opts2 or {}
                local min_v  = opts2.Range and opts2.Range[1] or 0
                local max_v  = opts2.Range and opts2.Range[2] or 100
                local inc    = opts2.Increment or 1
                -- CHANGE: space before suffix for "42 %" style
                local suffix = opts2.Suffix and (" " .. opts2.Suffix) or ""
                local val    = opts2.Default or min_v
                local f      = card(62)

                new("TextLabel", {
                    BackgroundTransparency = 1,
                    Position               = UDim2.new(0, 16, 0, 12),
                    Size                   = UDim2.new(1, -100, 0, 16),
                    Font                   = FONT_MED, TextSize = ts(13),
                    TextColor3             = theme.Foreground,
                    TextXAlignment         = Enum.TextXAlignment.Left,
                    Text                   = opts2.Label or "Slider",
                    Parent                 = f,
                })
                local valLbl = new("TextLabel", {
                    BackgroundTransparency = 1,
                    Position               = UDim2.new(1, -80, 0, 12),
                    Size                   = UDim2.new(0, 68, 0, 16),
                    Font                   = FONT_MED, TextSize = ts(12),
                    TextColor3             = theme.Primary,
                    TextXAlignment         = Enum.TextXAlignment.Right,
                    Text                   = tostring(val) .. suffix,
                    Parent                 = f,
                })

                local track = new("Frame", {
                    Position         = UDim2.new(0, 16, 1, -22),
                    Size             = UDim2.new(1, -32, 0, 5),
                    BackgroundColor3 = theme.SurfaceElevated,
                    BorderSizePixel  = 0,
                    Parent           = f,
                })
                corner(track, 3)
                local fill = new("Frame", {
                    Size             = UDim2.new((val - min_v) / (max_v - min_v), 0, 1, 0),
                    BackgroundColor3 = theme.Primary,
                    BorderSizePixel  = 0,
                    Parent           = track,
                })
                corner(fill, 3)

                local thumb = new("Frame", {
                    AnchorPoint      = Vector2.new(0.5, 0.5),
                    Position         = UDim2.new((val - min_v) / (max_v - min_v), 0, 0.5, 0),
                    Size             = UDim2.new(0, 12, 0, 12),
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    BorderSizePixel  = 0,
                    Parent           = track,
                    ZIndex           = track.ZIndex + 1,
                })
                corner(thumb, R_PILL)
                stroke(thumb, Color3.fromRGB(0, 0, 0), 1, 0.86)

                local hitArea = new("TextButton", {
                    Position               = UDim2.new(0, 16, 1, -34),
                    Size                   = UDim2.new(1, -32, 0, 28),
                    BackgroundTransparency = 1,
                    Text                   = "",
                    Parent                 = f,
                    ZIndex                 = f.ZIndex + 1,
                })
                hitArea.MouseEnter:Connect(function()
                    tw(thumb, TI_Q, { Size = UDim2.new(0, 16, 0, 16) })
                end)

                local changed = Signal.new()
                local api     = {}
                api._saveEnabled = opts2.Save ~= false
                api.Value        = val

                local dragging = false

                local function setAlpha(a)
                    a   = math.clamp(a, 0, 1)
                    local raw = min_v + (max_v - min_v) * a
                    raw = math.floor((raw / inc) + 0.5) * inc
                    raw = math.clamp(raw, min_v, max_v)
                    val            = raw
                    api.Value      = val
                    valLbl.Text    = tostring(val) .. suffix
                    fill.Size      = UDim2.new((val - min_v) / (max_v - min_v), 0, 1, 0)
                    thumb.Position = UDim2.new((val - min_v) / (max_v - min_v), 0, 0.5, 0)
                    changed:Fire(val)
                end

                hitArea.MouseLeave:Connect(function()
                    if not dragging then
                        tw(thumb, TI_Q, { Size = UDim2.new(0, 12, 0, 12) })
                    end
                end)

                local focused = false
                hitArea.MouseButton1Click:Connect(function()
                    focused = true
                    tw(thumb, TI_Q, { Size = UDim2.new(0, 16, 0, 16) })
                end)

                local arrowConn = routerListen("_began", function(input, gp)
                    if not focused or gp then return end
                    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
                    local step = inc / (max_v - min_v)
                    if input.KeyCode == Enum.KeyCode.Right or input.KeyCode == Enum.KeyCode.D then
                        setAlpha((val - min_v) / (max_v - min_v) + step)
                        Win._debouncedSave()
                    elseif input.KeyCode == Enum.KeyCode.Left or input.KeyCode == Enum.KeyCode.A then
                        setAlpha((val - min_v) / (max_v - min_v) - step)
                        Win._debouncedSave()
                    elseif input.KeyCode == Enum.KeyCode.Escape then
                        focused = false
                        tw(thumb, TI_Q, { Size = UDim2.new(0, 12, 0, 12) })
                    end
                end)
                table.insert(Win._connections, arrowConn)

                local defocusConn = routerListen("_began", function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 and focused then
                        local ap = hitArea.AbsolutePosition
                        local sz = hitArea.AbsoluteSize
                        local mp = input.Position
                        if not (mp.X >= ap.X and mp.X <= ap.X + sz.X
                             and mp.Y >= ap.Y and mp.Y <= ap.Y + sz.Y) then
                            focused = false
                            if not dragging then
                                tw(thumb, TI_Q, { Size = UDim2.new(0, 12, 0, 12) })
                            end
                        end
                    end
                end)
                table.insert(Win._connections, defocusConn)

                local uL1 = routerListen("_began", function(input)
                    if input.UserInputType ~= Enum.UserInputType.MouseButton1
                    and input.UserInputType ~= Enum.UserInputType.Touch then return end
                    local tp = track.AbsolutePosition; local ts_ = track.AbsoluteSize
                    local mp = input.Position
                    if mp.X >= tp.X - 8 and mp.X <= tp.X + ts_.X + 8
                    and mp.Y >= tp.Y - 12 and mp.Y <= tp.Y + ts_.Y + 12 then
                        dragging = true
                        tw(thumb, TI_Q, { Size = UDim2.new(0, 16, 0, 16) })
                        setAlpha((mp.X - tp.X) / ts_.X)
                    end
                end)
                local uL2 = routerListen("_ended", function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch then
                        if dragging then
                            dragging = false
                            tw(thumb, TI_Q, { Size = UDim2.new(0, 12, 0, 12) })
                            Win._debouncedSave()
                        end
                    end
                end)
                local uL3 = routerListen("_changed", function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
                    or input.UserInputType == Enum.UserInputType.Touch) then
                        setAlpha((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X)
                    end
                end)
                table.insert(Win._connections, uL1)
                table.insert(Win._connections, uL2)
                table.insert(Win._connections, uL3)

                function api:Set(v) setAlpha((v - min_v) / (max_v - min_v)) end
                function api:OnChanged(fn) return changed:Connect(safeCallback(fn, notifyFn)) end
                if opts2.Flag then Library.Flags[opts2.Flag] = api end
                if Win._pendingConfig and opts2.Flag and Win._pendingConfig[opts2.Flag] ~= nil then
                    api:Set(Win._pendingConfig[opts2.Flag])
                end
                return decorate(api, f, opts2)
            end

