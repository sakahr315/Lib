-- 2. SIGNAL  (lightweight event emitter, no external deps)
-- =========================================================================
--[[ @class Signal
     A simple signal that supports multiple listeners and per-connection disconnect. ]]
local Signal = {}
Signal.__index = Signal

--- Create a new Signal.
--- @return Signal
function Signal.new()
    return setmetatable({ _handlers = {} }, Signal)
end

--- Connect a handler. Returns a connection object with :Disconnect().
--- @param fn function
--- @return table
function Signal:Connect(fn)
    local id = {}
    self._handlers[id] = fn
    return {
        Disconnect = function()
            self._handlers[id] = nil
        end,
    }
end

--- Fire the signal, calling all handlers with the given arguments.
function Signal:Fire(...)
    for _, fn in pairs(self._handlers) do
        task.spawn(fn, ...)
    end
end

--- Disconnect all handlers.
function Signal:DisconnectAll()
    self._handlers = {}
end

-- =========================================================================
-- 3. INPUT ROUTER  (single global handler, components register here)
-- =========================================================================
local InputRouter = {
    _began   = {},  -- { id -> fn(input, gp) }
    _ended   = {},
    _changed = {},
}

local _routerConns = {}
_routerConns[1] = UIS.InputBegan:Connect(function(input, gp)
    for _, fn in pairs(InputRouter._began) do pcall(fn, input, gp) end
end)
_routerConns[2] = UIS.InputEnded:Connect(function(input, gp)
    for _, fn in pairs(InputRouter._ended) do pcall(fn, input, gp) end
end)
_routerConns[3] = UIS.InputChanged:Connect(function(input, gp)
    for _, fn in pairs(InputRouter._changed) do pcall(fn, input, gp) end
end)

local function routerListen(bucket, fn)
    local id = {}
    InputRouter[bucket][id] = fn
    return function() InputRouter[bucket][id] = nil end  -- returns unlisten()
end

